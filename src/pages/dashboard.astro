---
import Layout from '../layouts/Layout.astro';
import { requireAuth } from '../lib/auth';
import { supabaseAdmin, supabase } from '../lib/supabase';

const user = await requireAuth(Astro.cookies);
if (!user) return Astro.redirect('/signin');

// Use service role so RLS never blocks the profile read
const db = supabaseAdmin ?? supabase;

const { data: profile } = await db
  .from('customers')
  .select('first_name, last_name')
  .eq('id', user.id)
  .single();

// Check if this user is an admin
const { data: adminRow } = await db
  .from('admins')
  .select('id')
  .eq('id', user.id)
  .single();

const isAdmin = !!adminRow;

const { data: bookings } = await db
  .from('bookings')
  .select('id, start_date, end_date, event_type, status, total_price, venue_id')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(5);

// Fetch venue names separately to avoid join type issues
const venueIds = [...new Set((bookings ?? []).map(b => b.venue_id))];
const { data: venues } = venueIds.length > 0
  ? await db.from('venues').select('id, name').in('id', venueIds)
  : { data: [] };
const venueMap = Object.fromEntries((venues ?? []).map(v => [v.id, v.name]));

const displayName = profile?.first_name
  ? `${profile.first_name} ${profile.last_name ?? ''}`.trim()
  : user.email;
---

<Layout title="Dashboard">
  <div class="max-w-5xl mx-auto px-4 py-12">
    <div class="mb-10">
      <h1 class="text-3xl font-bold" style="color: var(--jet-primary);">
        Welcome back, {displayName}!
      </h1>
      <p class="text-gray-500 mt-1">{user.email}</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-10">
      <a href="/events_and_booking/events" class="card-container p-6 text-center hover:cursor-pointer">
        <div class="text-3xl mb-2">🏖️</div>
        <h3 class="font-bold" style="color: var(--butterscotch-primary);">Browse Venues</h3>
        <p class="text-sm text-gray-500 mt-1">Find your perfect event space</p>
      </a>
      <div class="card-container p-6 text-center">
        <div class="text-3xl mb-2">📅</div>
        <h3 class="font-bold" style="color: var(--butterscotch-primary);">My Bookings</h3>
        <p class="text-sm text-gray-500 mt-1">{bookings?.length ?? 0} recent bookings</p>
      </div>
      {isAdmin && (
        <a href="/admin" class="card-container p-6 text-center hover:cursor-pointer">
          <div class="text-3xl mb-2">⚙️</div>
          <h3 class="font-bold" style="color: var(--butterscotch-primary);">Admin Panel</h3>
          <p class="text-sm text-gray-500 mt-1">Manage bookings & venues</p>
        </a>
      )}
    </div>

    <div class="card-container p-6">
      <h2 class="text-xl font-bold mb-4" style="color: var(--jet-primary);">Recent Bookings</h2>
      {bookings && bookings.length > 0 ? (
        <div class="space-y-3">
          {bookings.map((b) => (
            <div class="flex justify-between items-center py-3 border-b border-gray-100 last:border-0">
              <div>
                <p class="font-semibold">{venueMap[b.venue_id] ?? 'Unknown Venue'}</p>
                <p class="text-sm text-gray-500">
                  {new Date(b.start_date).toLocaleDateString()} – {new Date(b.end_date).toLocaleDateString()}
                  {b.event_type ? ` · ${b.event_type}` : ''}
                </p>
              </div>
              <div class="text-right">
                <span class={`text-xs font-bold px-2 py-1 rounded-full ${
                  b.status === 'confirmed' ? 'bg-green-100 text-green-700' :
                  b.status === 'cancelled' ? 'bg-red-100 text-red-700' :
                  'bg-yellow-100 text-yellow-700'
                }`}>
                  {b.status}
                </span>
                {b.total_price && (
                  <p class="text-sm font-semibold mt-1" style="color: var(--butterscotch-primary);">
                    ₱{b.total_price.toLocaleString()}
                  </p>
                )}
              </div>
            </div>
          ))}
        </div>
      ) : (
        <p class="text-gray-500 text-center py-6">No bookings yet. <a href="/events_and_booking/events" class="underline" style="color: var(--butterscotch-primary);">Browse venues</a></p>
      )}
    </div>

    <div class="mt-8 text-right">
      <a href="/api/auth/signout"
        class="inline-block px-6 py-2 rounded-lg text-white font-semibold transition hover:opacity-80"
        style="background-color: var(--jet-primary);">
        Sign out
      </a>
    </div>
  </div>
</Layout>
