      if (res.ok) { closeReviewModal(); toast('⭐ Review submitted! Thank you.'); setTimeout(() => location.reload(), 1200); }
      else { const j = await res.json().catch(() => ({})); errEl.textContent = j.message || 'Something went wrong. Please try again.'; errEl.classList.remove('hidden'); btn.disabled = false; btn.textContent = 'Submit Review ⭐'; }
    } catch { errEl.textContent = 'Network error. Please try again.'; errEl.classList.remove('hidden'); btn.disabled = false; btn.textContent = 'Submit Review ⭐'; }
  }

  document.getElementById('bookingDetailsModal')?.addEventListener('click', e => { if (e.target === document.getElementById('bookingDetailsModal')) closeBookingDetails(); });
  document.getElementById('rescheduleModal')?.addEventListener('click', e => { if (e.target === document.getElementById('rescheduleModal')) closeRescheduleModal(); });
  document.getElementById('reviewModal')?.addEventListener('click', e => { if (e.target === document.getElementById('reviewModal')) closeReviewModal(); });

