import Layout from '../layouts/Layout.astro';
import { requireAuth } from '../lib/auth';
import { supabaseAdmin, supabase } from '../lib/supabase';
import { normalizeBookingStatus } from '../lib/bookingStatus';

const user = await requireAuth(Astro.cookies);
if (!user) return Astro.redirect('/signin');

const db = supabaseAdmin ?? supabase;

const { data: profile } = await db
  .from('customers')
  .select('first_name, last_name, email_notifications_enabled, sms_notifications_enabled')
  .eq('id', user.id)
  .single();

const { data: adminRow } = await db
  .from('admins').select('id').eq('id', user.id).single();
const isAdmin = !!adminRow;

const { data: bookings } = await db
  .from('bookings')
  .select('id, start_date, end_date, event_type, status, total_price, venue_id, event_date, created_at, updated_at, cancelled_at, rescheduled_at, pax, full_name, phone, special_requests, package_id')
  .eq('user_id', user.id)
  .order('created_at', { ascending: false })
  .limit(20);

