<!-- ── REVIEW MODAL ──────────────────────────────────────────────────────── -->
<script>
  const emailToggle = document.getElementById('emailNotificationsToggle') as HTMLInputElement | null;
  const smsToggle = document.getElementById('smsNotificationsToggle') as HTMLInputElement | null;
  const preferenceMessage = document.getElementById('notificationPreferenceMessage');

  function setPreferenceMessage(message: string, isSuccess: boolean) {
    if (!preferenceMessage) return;
    preferenceMessage.textContent = message;
    preferenceMessage.classList.remove('hidden', 'text-red-600', 'text-green-700');
    preferenceMessage.classList.add(isSuccess ? 'text-green-700' : 'text-red-600');
  }

  async function saveNotificationPreferences(changedToggle: HTMLInputElement) {
    if (!emailToggle || !smsToggle) return;

    if (!emailToggle.checked && !smsToggle.checked) {
      changedToggle.checked = true;
      setPreferenceMessage('At least one notification channel must remain enabled.', false);
      return;
    }

    const response = await fetch('/api/user/notification-preferences', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        emailNotificationsEnabled: emailToggle.checked,
        smsNotificationsEnabled: smsToggle.checked,
      }),
    });

    if (response.ok) {
      setPreferenceMessage('Notification preferences updated.', true);
      return;
    }

    const payload = await response.json().catch(() => ({}));
