<script>
  let _reviewBookingId = '';
  let _activeBookingId = '';

  function toast(message, good = true) {
    const t = document.createElement('div');
    t.textContent = message;
    t.style.cssText = `position:fixed;bottom:24px;right:24px;z-index:9999;background:${good ? '#10b981' : '#ef4444'};color:white;padding:14px 20px;border-radius:14px;font-weight:700;font-size:0.875rem;box-shadow:0 8px 24px rgba(0,0,0,0.15);`;
    document.body.appendChild(t);
    setTimeout(() => t.remove(), 2400);
  }

  function openBookingDetails(btn) {
    const card = btn.closest('.booking-card');
    if (!card) return;
    _activeBookingId = card.dataset.bookingId || '';
    const set = (id, value) => { const el = document.getElementById(id); if (el) el.textContent = value || '—'; };
    set('detailVenue', card.dataset.venue);
    set('detailStatus', card.dataset.status);
    set('detailStart', card.dataset.start);
    set('detailEnd', card.dataset.end);
    set('detailEvent', card.dataset.event);
    set('detailName', card.dataset.name);
    set('detailPhone', card.dataset.phone);
    set('detailType', card.dataset.type);
    set('detailPax', card.dataset.pax);
    set('detailPackage', card.dataset.package);
    set('detailTotal', card.dataset.total);
    set('detailRequests', card.dataset.requests);
    set('detailCreated', card.dataset.created);
    set('detailUpdated', card.dataset.updated);

    const canManage = card.dataset.canManage === 'yes';
    const cancelBtn = document.getElementById('cancelBookingBtn');
    const rescheduleBtn = document.getElementById('openRescheduleBtn');
    const note = document.getElementById('detailActionNote');
    if (cancelBtn) cancelBtn.style.display = canManage ? '' : 'none';
    if (rescheduleBtn) rescheduleBtn.style.display = canManage ? '' : 'none';
    if (note) note.textContent = canManage ? 'You can cancel this booking or send a reschedule request while it is active.' : 'This booking can no longer be changed from the dashboard.';

    const s = document.getElementById('newStartDate');
    const e = document.getElementById('newEndDate');
    const ev = document.getElementById('newEventDate');
    if (s) s.value = card.dataset.startRaw || '';
    if (e) e.value = card.dataset.endRaw || '';
    if (ev) ev.value = card.dataset.eventRaw || '';

    document.getElementById('bookingDetailsModal')?.classList.remove('hidden');
  }

  function closeBookingDetails() { document.getElementById('bookingDetailsModal')?.classList.add('hidden'); }
  function openRescheduleModal() { document.getElementById('rescheduleModal')?.classList.remove('hidden'); }
  function closeRescheduleModal() { document.getElementById('rescheduleModal')?.classList.add('hidden'); }

  async function cancelBooking() {
    if (!_activeBookingId) return;
    if (!confirm('Are you sure you want to cancel this booking?')) return;
    const btn = document.getElementById('cancelBookingBtn');
    if (btn) { btn.disabled = true; btn.textContent = 'Cancelling...'; }
    try {
      const res = await fetch('/api/bookings/CancelBookings', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ bookingId: _activeBookingId })
      });
      const j = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(j.message || 'Unable to cancel booking.');
      toast('Booking cancelled successfully.');
      setTimeout(() => location.reload(), 900);
    } catch (err) {
      toast(err.message || 'Unable to cancel booking.', false);
      if (btn) { btn.disabled = false; btn.textContent = 'Cancel Booking'; }
    }
  }

  async function submitRescheduleRequest() {
    const errEl = document.getElementById('rescheduleError');
    const btn = document.getElementById('submitRescheduleBtn');
    const newStartDate = document.getElementById('newStartDate')?.value;
    const newEndDate = document.getElementById('newEndDate')?.value;
    const newEventDate = document.getElementById('newEventDate')?.value;
    const reason = document.getElementById('rescheduleReason')?.value.trim();
    if (errEl) { errEl.classList.add('hidden'); errEl.textContent = ''; }
    if (!newStartDate || !newEndDate) { if (errEl) { errEl.textContent = 'Please choose new check-in and check-out dates.'; errEl.classList.remove('hidden'); } return; }
    if (new Date(newEndDate) <= new Date(newStartDate)) { if (errEl) { errEl.textContent = 'Check-out must be after check-in.'; errEl.classList.remove('hidden'); } return; }
    if (btn) { btn.disabled = true; btn.textContent = 'Sending...'; }
    try {
      const res = await fetch('/api/bookings/RequestReschedule', {
        method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify({ bookingId: _activeBookingId, newStartDate, newEndDate, newEventDate, reason })
      });
      const j = await res.json().catch(() => ({}));
      if (!res.ok) throw new Error(j.message || 'Unable to send reschedule request.');
      toast('Reschedule request sent.');
      setTimeout(() => location.reload(), 900);
    } catch (err) {
      if (errEl) { errEl.textContent = err.message || 'Unable to send reschedule request.'; errEl.classList.remove('hidden'); }
      if (btn) { btn.disabled = false; btn.textContent = 'Send Reschedule Request'; }
    }
  }

  function openReviewModal(bookingId, venueName) {
    _reviewBookingId = bookingId;
    const nameEl = document.getElementById('reviewVenueName');
    if (nameEl) nameEl.textContent = venueName;
    document.getElementById('reviewRating').value = '0';
    document.getElementById('reviewComment').value = '';
    const errEl = document.getElementById('reviewError');
    if (errEl) { errEl.classList.add('hidden'); errEl.textContent = ''; }
    updateStars(0);
    document.getElementById('reviewModal')?.classList.remove('hidden');
  }
  function closeReviewModal() { document.getElementById('reviewModal')?.classList.add('hidden'); }
  function updateStars(rating) { document.querySelectorAll('.star-btn').forEach(btn => { const n = parseInt(btn.dataset.star || '0'); btn.style.color = n <= rating ? '#f59e0b' : '#e5e7eb'; btn.style.transform = n === rating ? 'scale(1.2)' : ''; }); }
  document.querySelectorAll('.star-btn').forEach(btn => { btn.addEventListener('mouseenter', () => updateStars(parseInt(btn.dataset.star || '0'))); btn.addEventListener('mouseleave', () => updateStars(parseInt(document.getElementById('reviewRating').value))); btn.addEventListener('click', () => { const n = parseInt(btn.dataset.star || '0'); document.getElementById('reviewRating').value = String(n); updateStars(n); }); });
  async function submitReview() {
    const rating = parseInt(document.getElementById('reviewRating').value);
    const comment = document.getElementById('reviewComment').value.trim();
