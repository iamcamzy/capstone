---
import ShowButton from '../components/showButton.astro';
import Layout from '../layouts/Layout.astro';
export const prerender = false;

const { cookies, url } = Astro;
const hasSession = cookies.get('sb-access-token') && cookies.get('sb-refresh-token');
if (hasSession) return Astro.redirect('/dashboard');

const errorMsg = url.searchParams.get('error');
---

<Layout title="Sign in">
  <div class="auth-page w-full min-h-[69vh] flex justify-center items-center py-12 px-4">
    <div id="formBox" class="auth-card w-full max-w-md ring-2 rounded-xl">
      <div id="formHeader" class="auth-card__header border-b w-full px-6 py-4 flex justify-between items-center">
        <h1 class="text-2xl font-bold">Log in</h1>
        <a href="/" class="auth-back flex justify-center items-center text-sm rounded-2xl py-1 px-4 ring-1 text-white">Back</a>
      </div>

      {errorMsg && (
        <div class="mx-6 mt-4 p-3 bg-red-50 border border-red-200 rounded-lg text-red-700 text-sm">
          {decodeURIComponent(errorMsg)}
        </div>
      )}

      <form action="/api/auth/signin" method="post" class="px-6 py-8 space-y-5">
        <div>
          <label for="email" class="block text-sm font-bold mb-1">Email</label>
          <input id="email" name="email" type="email" required
            class="w-full p-2 pl-4 rounded ring focus:outline-none focus:ring-2" />
        </div>
        <div class="relative">
          <label for="password" class="block text-sm font-bold mb-1">Password</label>
          <input id="password" name="password" type="password" required
            class="w-full p-2 pl-4 rounded ring focus:outline-none focus:ring-2" />
          <ShowButton />
        </div>
        <button type="submit"
          class="auth-submit w-full text-lg text-white font-bold rounded-2xl py-2 px-5 hover:cursor-pointer transition">
          Log in
        </button>
      </form>
      <p class="flex justify-end pb-4 px-6 gap-2 text-sm">
        New here?
        <a href="/signup" class="auth-link underline">Create an account</a>
      </p>
    </div>
  </div>
</Layout>

<style>
  .auth-page {
    background:
      radial-gradient(circle at 12% 8%, rgba(232, 242, 227, 0.78), transparent 26rem),
      var(--wb-surface);
  }

  .auth-card {
    overflow: hidden;
    border: 1px solid var(--wb-border);
    background: var(--wb-surface-raised);
    box-shadow: var(--wb-shadow-md);
    color: var(--wb-text);
  }

  .auth-card__header {
    border-color: var(--wb-border);
    background: var(--wb-surface-soft);
  }

  .auth-card h1 {
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    letter-spacing: 0;
  }

  .auth-card input {
    border: 1px solid var(--wb-border);
    background: #fff;
    color: var(--wb-text);
  }

  .auth-card input:focus {
    border-color: var(--wb-green);
    box-shadow: 0 0 0 4px rgba(74, 124, 63, 0.12);
  }

  .auth-back {
    border-color: rgba(154, 74, 54, 0.32);
    background: #9a4a36;
    text-decoration: none;
  }

  .auth-submit {
    background: var(--wb-green);
  }

  .auth-submit:hover {
    background: var(--wb-green-mid);
  }

  .auth-link {
    color: var(--wb-green-mid);
    font-weight: 700;
  }

  :global(html.dark) .auth-page {
    background:
      radial-gradient(circle at 12% 8%, rgba(37, 56, 35, 0.72), transparent 26rem),
      var(--wb-surface);
  }

  :global(html.dark) .auth-card input {
    background: var(--wb-surface-soft) !important;
    color: var(--wb-text) !important;
  }
</style>
