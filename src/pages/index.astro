---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
import { getUser } from '../lib/auth';
import { supabase, supabaseAdmin } from '../lib/supabase';

const user = await getUser(Astro.cookies);

let isAdmin = false;
if (user) {
  const client = supabaseAdmin ?? supabase;
  const { data } = await client
    .from('admins')
    .select('id')
    .eq('id', user.id)
    .single();
  isAdmin = !!data;
}
---

<Layout>
  <div class="wb-page">

    <!-- HERO -->
    <section class="wb-hero">
      <div class="wb-hero__content">
        <p class="wb-hero__eyebrow">WELCOME TO WOODBERRY</p>
        <h1 class="wb-hero__heading">Memorable Stays.<br/>Seamless Events.</h1>
        <p class="wb-hero__sub">Your perfect venue for every occasion — from intimate gatherings to grand celebrations, nestled in nature.</p>
        <div class="wb-booking-highlight" aria-label="Booking benefits">
          <span>✓ Easy date checking</span>
          <span>✓ Fast request review</span>
          <span>✓ Perfect for events</span>
        </div>
        <div class="wb-hero__actions">
          {isAdmin ? (
            <a href="/admin" class="wb-btn wb-btn--primary">
              Admin Dashboard <span>⚙️</span>
            </a>
          ) : (
            <a href="/events_and_booking/events" class="wb-btn wb-btn--primary wb-btn--booking">
              Book Now <span>🗓</span>
            </a>
          )}
          <a href="/gallery" class="wb-btn wb-btn--outline">
            Explore Resort <span>→</span>
          </a>
        </div>
      </div>

      <div class="wb-hero__leaf-left" aria-hidden="true">
        <svg viewBox="0 0 180 320" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M20 300 Q-40 150 80 20 Q160 100 120 200 Q80 260 20 300Z" fill="#c8dbb8" opacity="0.5"/>
          <path d="M50 310 Q10 200 90 80" stroke="#a8c890" stroke-width="2" fill="none" opacity="0.6"/>
        </svg>
      </div>

      <div class="wb-hero__image-wrap">
        <!-- Hidden SVG that defines the wavy clip shape -->
        <svg width="0" height="0" style="position:absolute;">
          <defs>
            <clipPath id="wavyClip" clipPathUnits="objectBoundingBox">
              <!-- wavy S-curve on the left, straight on right/top/bottom -->
              <path d="M 0.13,0 C 0.0,0.15 0.22,0.3 0.08,0.5 C -0.04,0.68 0.1,0.85 0.13,1 L 1,1 L 1,0 Z"/>
            </clipPath>
          </defs>
        </svg>
        <img src="/woodberyPics/pool_and_house.jpg" alt="Woodberry resort" class="wb-hero__img" width="1200" height="800" loading="eager" decoding="async" fetchpriority="high" />
        <div class="wb-hero__leaf-top" aria-hidden="true">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path d="M200 0 Q80 20 60 100 Q80 160 160 200 Q200 140 200 0Z" fill="#5a8a3a" opacity="0.85"/>
            <path d="M200 0 Q120 60 100 160" stroke="#3d6b28" stroke-width="2" fill="none"/>
          </svg>
        </div>
      </div>
    </section>

    <!-- FEATURE CARDS -->
    <section class="wb-features">
      <div class="wb-features__grid">

        <div class="wb-feature-card">
          <div class="wb-feature-card__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
              <rect x="4" y="16" width="32" height="20" rx="2" stroke="#4a7c3f" stroke-width="2"/>
              <path d="M4 20 L20 8 L36 20" stroke="#4a7c3f" stroke-width="2" stroke-linejoin="round"/>
              <rect x="14" y="26" width="6" height="10" rx="1" fill="#4a7c3f"/>
              <rect x="22" y="22" width="8" height="6" rx="1" stroke="#4a7c3f" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="wb-feature-card__body">
            <h3>Stunning Venue</h3>
            <p>A beautiful resort setting for any occasion.</p>
          </div>
        </div>

        <div class="wb-feature-card">
          <div class="wb-feature-card__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
              <rect x="4" y="8" width="32" height="28" rx="2" stroke="#4a7c3f" stroke-width="2"/>
              <line x1="4" y1="16" x2="36" y2="16" stroke="#4a7c3f" stroke-width="2"/>
              <line x1="14" y1="4" x2="14" y2="12" stroke="#4a7c3f" stroke-width="2" stroke-linecap="round"/>
              <line x1="26" y1="4" x2="26" y2="12" stroke="#4a7c3f" stroke-width="2" stroke-linecap="round"/>
              <rect x="10" y="21" width="5" height="5" rx="1" fill="#4a7c3f"/>
              <rect x="18" y="21" width="5" height="5" rx="1" fill="#4a7c3f"/>
              <rect x="26" y="21" width="5" height="5" rx="1" fill="#4a7c3f"/>
            </svg>
          </div>
          <div class="wb-feature-card__body">
            <h3>Easy Booking</h3>
            <p>Reserve your date in just a few clicks.</p>
          </div>
        </div>

        <div class="wb-feature-card">
          <div class="wb-feature-card__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
              <circle cx="20" cy="14" r="6" stroke="#4a7c3f" stroke-width="2"/>
              <path d="M8 36 Q8 28 20 26 Q32 28 32 36" stroke="#4a7c3f" stroke-width="2" fill="none" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="wb-feature-card__body">
            <h3>Any Occasion</h3>
            <p>Weddings, reunions, parties & more.</p>
          </div>
        </div>

        <div class="wb-feature-card">
          <div class="wb-feature-card__icon">
            <svg viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg" width="22" height="22">
              <path d="M12 2 Q4 8 4 18 Q4 28 12 32 Q20 36 28 32 Q36 28 36 18 Q36 8 28 2 Q20 -2 12 2Z" stroke="#4a7c3f" stroke-width="2" fill="none"/>
              <path d="M12 18 Q20 10 28 18" stroke="#4a7c3f" stroke-width="2" fill="none" stroke-linecap="round"/>
              <line x1="20" y1="32" x2="20" y2="18" stroke="#4a7c3f" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="wb-feature-card__body">
            <h3>Nature & Comfort</h3>
            <p>Lush greenery and modern amenities.</p>
          </div>
        </div>

      </div>

      <!-- Tagline -->
      <!-- <div class="wb-tagline">
        <svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" width="18" height="18">
          <path d="M12 2 Q4 8 4 16 Q4 22 12 22 Q20 22 20 16 Q20 8 12 2Z" fill="#4a7c3f" opacity="0.7"/>
          <line x1="12" y1="22" x2="12" y2="10" stroke="#4a7c3f" stroke-width="1.5" stroke-linecap="round"/>
        </svg>
        <p>Nature. Comfort. Memories.</p>
      </div> -->
    </section>

  </div>
</Layout>

<style>
  /* The whole page = exactly one screen height */
  .wb-page {
    display: flex;
    flex-direction: column;
    height: calc(100vh - 70px); /* subtract header */
    overflow: hidden;
    background: #f2f5ee;
  }

  /* Hero grows to fill whatever space is left above the cards */
  .wb-hero {
    position: relative;
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    flex: 1;
    min-height: 0;
    padding: 0 3% 0 6%;
    overflow: hidden;
  }

  /* Push content left so image has full right half */
  .wb-hero__content {
    position: relative;
    z-index: 2;
    grid-column: 1;
  }

  .wb-hero__content {
    position: relative;
    z-index: 2;
  }

  .wb-hero__eyebrow {
    color: #4a7c3f;
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.18em;
    margin-bottom: 0.5rem;
  }

  .wb-hero__heading {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(1.6rem, 2.8vw, 2.8rem);
    font-weight: 800;
    line-height: 1.1;
    color: #1a2e10;
    margin-bottom: 0.6rem;
  }

  .wb-hero__sub {
    font-size: 0.875rem;
    color: #4a5a42;
    line-height: 1.55;
    margin-bottom: 1.2rem;
    max-width: 380px;
  }

  .wb-booking-highlight {
    display: flex;
    flex-wrap: wrap;
    gap: 0.45rem;
    margin: 0 0 1rem;
    max-width: 430px;
  }
  .wb-booking-highlight span {
    background: rgba(255,255,255,0.78);
    border: 1px solid #dce8d4;
    color: #2d5a27;
    border-radius: 999px;
    padding: 0.42rem 0.65rem;
    font-size: 0.72rem;
    font-weight: 700;
    box-shadow: 0 6px 18px rgba(74,124,63,0.08);
  }

  .wb-hero__actions {
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .wb-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    padding: 0.6rem 1.3rem;
    border-radius: 8px;
    font-weight: 600;
    font-size: 0.875rem;
    text-decoration: none;
    transition: all 0.2s ease;
  }
  .wb-btn--primary { background: #1a1a1a; color: white; }
  .wb-btn--primary:hover { background: #333; transform: translateY(-1px); }
  .wb-btn--booking { background: linear-gradient(135deg,#2d5a27,#4a7c3f); box-shadow: 0 10px 24px rgba(45,90,39,.22); }
  .wb-btn--booking:hover { background: linear-gradient(135deg,#23491f,#3f7135); }
  .wb-btn--outline { background: transparent; color: #2d4a1e; border: 2px solid #4a7c3f; }
  .wb-btn--outline:hover { background: #e8f0e3; }

  /* Hero image — wavy left cut */
  .wb-hero__image-wrap {
    position: absolute;
    top: 0;
    right: 0;
    width: 58%;
    height: 100%;
    overflow: hidden;
    clip-path: url(#wavyClip);
  }
  .wb-hero__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }

  .wb-hero__leaf-left {
    position: absolute;
    left: -20px;
    bottom: 10px;
    width: 90px;
    opacity: 0.6;
    pointer-events: none;
    z-index: 1;
  }
  .wb-hero__leaf-top {
    position: absolute;
    top: -10px;
    right: -10px;
    width: 110px;
    height: 110px;
    pointer-events: none;
  }

  /* Feature cards — fixed height strip at the bottom */
  .wb-features {
    flex-shrink: 0;
    background: #f7f9f4;
    border-top: 1px solid #dde8d4;
    padding: 0.55rem 5% 0.4rem;
  }

  .wb-features__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.55rem;
    max-width: 1200px;
    margin: 0 auto 0.4rem;
  }

  .wb-feature-card {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.5rem 0.7rem;
    background: white;
    border-radius: 10px;
    box-shadow: 0 1px 4px rgba(0,0,0,0.06);
    transition: box-shadow 0.2s;
  }
  .wb-feature-card:hover { box-shadow: 0 4px 16px rgba(74,124,63,0.12); }

  .wb-feature-card__icon {
    flex-shrink: 0;
    width: 34px;
    height: 34px;
    background: #e8f2e3;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .wb-feature-card__body h3 {
    font-size: 0.78rem;
    font-weight: 700;
    color: #1a2e10;
    margin: 0 0 0.1rem;
  }
  .wb-feature-card__body p {
    font-size: 0.7rem;
    color: #5a6b52;
    line-height: 1.4;
    margin: 0;
  }

  /* Tagline */
  .wb-tagline {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    padding-bottom: 0.1rem;
  }
  .wb-tagline p {
    font-family: Georgia, serif;
    font-size: 0.8rem;
    color: #2d4a1e;
    font-style: italic;
    margin: 0;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .wb-page { height: auto; overflow: auto; }
    .wb-hero { grid-template-columns: 1fr; padding: 2rem 5%; flex: none; min-height: 60vh; }
    .wb-hero__image-wrap { display: none; }
    .wb-features__grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 480px) {
    .wb-features__grid { grid-template-columns: 1fr; }
  }
</style>