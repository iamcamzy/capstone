---
import Layout from '../../layouts/Layout.astro';
import EventCard from '../../components/eventCards/eventCard.astro';
import { getUser } from '../../lib/auth';
import { getAllVenues } from '../../services/venues';

const user = await getUser(Astro.cookies);
const isLoggedIn = Boolean(user);
const { data: venues } = await getAllVenues();
const venuesToDisplay = venues || [];
---

<Layout>
  <div
    id="top-runner"
    class="w-full py-12"
    style="background: linear-gradient(135deg, #1a2e10 0%, #2d5a27 68%, #4a7c3f 100%);"
  >
    <div class="max-w-6xl mx-auto px-4">
      <h1 class="text-4xl font-bold mb-4 text-white!">
        DISCOVER AMAZING VENUES!
      </h1>
      <p class="text-lg opacity-90 text-white!">
        Find the perfect space for your next event from our curated selection
      </p>
    </div>
  </div>

  <div id="main-showcase" class="w-full py-12">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-gray-600 mb-8 text-sm uppercase font-semibold">
        Showing our available venues
      </p>
      <div
        class="w-full h-auto grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6"
      >
        {
          venuesToDisplay.map((venue) => (
            <EventCard venue={venue} isLoggedIn={isLoggedIn} />
          ))
        }
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(:root) {
    --lion-primary: #aa8f66;
    --butterscotch-primary: #ed9b40;
    --jet-primary: #363537;
  }

  #main-showcase {
    background: var(--wb-surface);
    color: var(--wb-text);
  }

  :global(html.dark) #top-runner {
    border-bottom: 1px solid var(--wb-border);
    box-shadow: var(--wb-shadow-md);
  }
</style>
