---
import Layout from '../../../layouts/Layout.astro';
import { getVenue } from '../../../services/venues';
import BookingForm from '../../../components/bookingForm.astro';

const { venueId } = Astro.params;

if (!venueId) return Astro.redirect('/events_and_booking/events');

const { data, error } = await getVenue(venueId);

if (error || !data) return Astro.redirect('/events_and_booking/events');

const venue = {
  id: data.id,
  name: data.name || 'Unknown Venue',
  image_url: data.image_url ?? undefined,
  price_per_night: data.price_per_night || 0,
  capacity: data.capacity ?? undefined,
  description: data.description ?? undefined,
};

const now = new Date();
const monthName = now.toLocaleString('en-PH', { month: 'long', year: 'numeric' });
---

<Layout>
  <!-- Hero Section -->
  <div
    id="top-runner"
    class="w-full py-12 text-white"
    style="background-color: var(--jet-primary);"
  >
    <div class="max-w-6xl mx-auto px-4">
      <a
        href="/events_and_booking/events"
        class="inline-flex items-center gap-2 mb-6 text-butterscotch-500 hover:text-butterscotch-400 transition-colors"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Events
      </a>
      <h1 class="text-4xl font-bold mb-2">{venue.name}</h1>
      <p class="text-lg opacity-90">
        Complete your booking for this amazing venue
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="w-full py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Venue Details -->
        <div class="lg:col-span-1">
          <div
            class="bg-white rounded-lg border border-gray-200 overflow-hidden sticky top-20"
          >
            {
              venue.image_url && (
                <img
                  src={venue.image_url || '/placeholder.svg'}
                  alt={venue.name}
                  class="w-full h-48 object-cover"
                  width="640"
                  height="360"
                  loading="eager"
                  decoding="async"
                />
              )
            }
            <div class="p-6">
              <h3
                class="text-xl font-bold mb-4"
                style="color: var(--jet-primary);"
              >
                Booking Details
              </h3>

              <div class="space-y-4">
                <div
                  class="flex justify-between items-center pb-4 border-b border-gray-200"
                >
                  <span class="text-gray-600">Price per Night</span>
                  <span
                    class="text-2xl font-bold"
                    style="color: var(--butterscotch-primary);"
                  >
                    ${venue.price_per_night.toFixed(2)}
                  </span>
                </div>

                {
                  venue.capacity && (
                    <div class="pb-4 border-b border-gray-200">
                      <span class="text-gray-600 text-sm">Capacity</span>
                      <p
                        class="font-semibold"
                        style="color: var(--jet-primary);"
                      >
                        {venue.capacity} guests
                      </p>
                    </div>
                  )
                }

                {
                  venue.description && (
                    <div>
                      <span class="text-gray-600 text-sm">About</span>
                      <p class="text-sm text-gray-700 mt-2">
                        {venue.description}
                      </p>
                    </div>
                  )
                }
              </div>



              <div class="mt-6 pt-6 border-t border-gray-200">
                <div class="flex items-center justify-between mb-3">
                  <div>
                    <p class="text-xs font-bold uppercase tracking-widest text-gray-400">Visible Availability</p>
                    <p id="venueAvailabilityMonth" class="text-sm font-semibold" style="color:var(--jet-primary);">{monthName}</p>
                  </div>
                  <div id="venueAvailabilityLoading" class="text-xs text-gray-400">Loading…</div>
                </div>
                <div id="venueAvailabilityGrid" class="venue-availability-grid" aria-label="Venue availability calendar"></div>
                <div class="venue-availability-legend">
                  <span><i style="background:#22c55e"></i> Available</span>
                  <span><i style="background:#ef4444"></i> Booked</span>
                  <span><i style="background:#f59e0b"></i> Pending</span>
                </div>
              </div>

              <div class="mt-6 pt-6 border-t border-gray-200">
                <p class="text-xs text-gray-500 text-center">
                  You'll receive a confirmation email after booking
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Booking Form -->
        <div class="lg:col-span-2">
          <div class="booking-stepper" aria-label="Booking progress">
            <div class="booking-stepper__item is-done"><p>Select Venue</p></div>
            <div class="booking-stepper__item is-active"><p>Details</p></div>
            <div class="booking-stepper__item"><p>Review</p></div>
            <div class="booking-stepper__item"><p>Submit</p></div>
          </div>
          <div class="bg-white rounded-lg border border-gray-200 p-8">
            <BookingForm
              venueId={venue.id}
              venueName={venue.name}
              pricePerNight={venue.price_per_night}
            />
          </div>
        </div>
      </div>
    </div>
  </div>
</Layout>

<script is:inline define:vars={{ venueId: venue.id }}>
  const grid = document.getElementById('venueAvailabilityGrid');
  const loading = document.getElementById('venueAvailabilityLoading');
  const today = new Date();

  function isoDate(year, month, day) {
    return `${year}-${String(month + 1).padStart(2, '0')}-${String(day).padStart(2, '0')}`;
  }

  async function renderVenueAvailability() {
    if (!grid) return;
    const year = today.getFullYear();
    const month = today.getMonth();
    const booked = new Set();
    const pending = new Set();

    try {
      const res = await fetch(`/api/bookings/availability?year=${year}&month=${month + 1}&venueId=${venueId}`);
      const json = await res.json();
      for (const b of (json.bookings || [])) {
        const start = new Date((b.start_date || b.event_date) + 'T00:00:00');
        const end = new Date((b.end_date || b.event_date || b.start_date) + 'T00:00:00');
        for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
          const key = d.toISOString().split('T')[0];
          if (b.status === 'pending') pending.add(key);
          else booked.add(key);
        }
      }
    } catch (e) {
      console.warn('Could not load availability', e);
    } finally {
      if (loading) loading.textContent = '';
    }

    const firstDow = new Date(year, month, 1).getDay();
    const offset = (firstDow + 6) % 7;
    const daysInMonth = new Date(year, month + 1, 0).getDate();
    const totalCells = Math.ceil((offset + daysInMonth) / 7) * 7;
    const todayISO = today.toISOString().split('T')[0];

    grid.innerHTML = '';
    ['M','T','W','T','F','S','S'].forEach((d) => {
      const el = document.createElement('div');
      el.className = 'venue-availability-day venue-availability-day--head';
      el.textContent = d;
      grid.appendChild(el);
    });

    for (let i = 0; i < totalCells; i++) {
      const day = i - offset + 1;
      const cell = document.createElement('div');
      cell.className = 'venue-availability-day';
      if (day < 1 || day > daysInMonth) {
        cell.classList.add('is-empty');
      } else {
        const key = isoDate(year, month, day);
        cell.textContent = String(day);
        if (key < todayISO) cell.classList.add('is-past');
        else if (booked.has(key)) cell.classList.add('is-booked');
        else if (pending.has(key)) cell.classList.add('is-pending');
        else cell.classList.add('is-available');
      }
      grid.appendChild(cell);
    }
  }

  renderVenueAvailability();
</script>

<style>
  :global(:root) {
    --lion-primary: #aa8f66;
    --butterscotch-primary: #ed9b40;
    --jet-primary: #363537;
  }
  .booking-stepper {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    margin-bottom: 1rem;
  }
  .booking-stepper__item {
    background: #fff;
    border: 1px solid #e5e7eb;
    border-radius: 14px;
    padding: 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: #6b7280;
    font-weight: 800;
    font-size: 0.8rem;
  }
.booking-stepper__item.is-active { border-color: #2d5a27; color: #1a2e10; box-shadow: 0 10px 24px rgba(45,90,39,.12); }
  .venue-availability-grid { display:grid; grid-template-columns:repeat(7,1fr); gap:4px; }
  .venue-availability-day { aspect-ratio:1; border-radius:8px; display:grid; place-items:center; font-size:.72rem; font-weight:800; background:#f8fafc; color:#94a3b8; }
  .venue-availability-day--head { aspect-ratio:auto; background:transparent; color:#64748b; font-size:.65rem; }
  .venue-availability-day.is-available { background:#f0fdf4; color:#166534; border:1px solid #86efac; }
  .venue-availability-day.is-booked { background:#fef2f2; color:#991b1b; border:1px solid #fecaca; }
  .venue-availability-day.is-pending { background:#fffbeb; color:#92400e; border:1px solid #fde68a; }
  .venue-availability-day.is-past { background:#f9fafb; color:#d1d5db; }
  .venue-availability-day.is-empty { background:transparent; }
  .venue-availability-legend { display:flex; gap:.65rem; flex-wrap:wrap; margin-top:.75rem; font-size:.68rem; color:#64748b; }
  .venue-availability-legend span { display:flex; align-items:center; gap:.3rem; }
  .venue-availability-legend i { width:9px; height:9px; border-radius:50%; display:inline-block; }
  @media(max-width:640px){ .booking-stepper{grid-template-columns:1fr 1fr}.booking-stepper__item{font-size:.72rem;padding:.6rem} }
</style>
