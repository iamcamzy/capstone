---
import Layout from '../../../layouts/Layout.astro';
import { getVenue } from '../../../services/venues';
import BookingForm from '../../../components/bookingForm.astro';
import { getUser } from '../../../lib/auth';

const { venueId } = Astro.params;

if (!venueId) return Astro.redirect('/events_and_booking/events');

const { data, error } = await getVenue(venueId);
const user = await getUser(Astro.cookies);

if (error || !data) return Astro.redirect('/events_and_booking/events');

const venue = {
  id: data.id,
  name: data.name || 'Unknown Venue',
  image_url: data.image_url ?? undefined,
  price_per_night: data.price_per_night || 0,
  capacity: data.capacity ?? undefined,
  description: data.description ?? undefined,
};
---

<Layout>
  <main class="wb-page-surface booking-page">
    <!-- Hero Section -->
    <div id="top-runner" class="booking-page__hero">
      <div class="max-w-6xl mx-auto px-4">
      <a
        href="/events_and_booking/events"
        class="booking-page__back"
      >
        <svg
          class="w-5 h-5"
          fill="none"
          stroke="currentColor"
          viewBox="0 0 24 24"
        >
          <path
            stroke-linecap="round"
            stroke-linejoin="round"
            stroke-width="2"
            d="M15 19l-7-7 7-7"></path>
        </svg>
        Back to Events
      </a>
      <p class="booking-page__eyebrow">Woodberry Booking Request</p>
      <h1>{venue.name}</h1>
      <p class="booking-page__intro">
        Complete your request with your event details, preferred facilities, and
        contract signing payment estimate.
      </p>
    </div>
  </div>

  <!-- Main Content -->
  <div class="w-full py-10 md:py-12">
    <div class="max-w-6xl mx-auto px-4">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <!-- Venue Details -->
        <div class="lg:col-span-1">
          <div
            class="booking-page__venue-card sticky top-20"
          >
            {
              venue.image_url && (
                <img
                  src={venue.image_url || '/placeholder.svg'}
                  alt={venue.name}
                  class="w-full h-48 object-cover"
                />
              )
            }
            <div class="p-6">
              <h3
                class="booking-page__card-title"
              >
                Venue Snapshot
              </h3>

              <div class="space-y-4">
                <div
                  class="booking-page__detail-row"
                >
                  <span>Price per Night</span>
                  <span
                    class="booking-page__price"
                  >
                    PHP {venue.price_per_night.toFixed(2)}
                  </span>
                </div>

                {
                  venue.capacity && (
                    <div class="booking-page__detail-block">
                      <span>Capacity</span>
                      <p>
                        {venue.capacity} guests
                      </p>
                    </div>
                  )
                }

                {
                  venue.description && (
                    <div class="booking-page__about">
                      <span>About</span>
                      <p>
                        {venue.description}
                      </p>
                    </div>
                  )
                }
              </div>

              <div class="booking-page__note">
                <p>
                  You will receive updates after the request is submitted.
                </p>
              </div>
            </div>
          </div>
        </div>

        <!-- Booking Form -->
        <div class="lg:col-span-2">
          {
            user ? (
              <div class="booking-page__form-card">
                <BookingForm
                  venueId={venue.id}
                  venueName={venue.name}
                  pricePerNight={venue.price_per_night}
                />
              </div>
            ) : (
              <section
                class="booking-page__login-panel"
                aria-labelledby="booking-login-required-title"
              >
                <p class="booking-page__login-eyebrow">Booking Access</p>
                <h2 id="booking-login-required-title">Sign in to book</h2>
                <p class="booking-page__login-message">
                  You must be logged in to book this venue.
                </p>
                <div class="booking-page__login-actions">
                  <a
                    href="/signin"
                    class="booking-page__login-button booking-page__login-button--primary"
                  >
                    Log In
                  </a>
                  <a
                    href="/signup"
                    class="booking-page__login-button booking-page__login-button--secondary"
                  >
                    Sign Up
                  </a>
                  <a
                    href="/events_and_booking/events"
                    class="booking-page__login-button booking-page__login-button--ghost"
                  >
                    Back to Events
                  </a>
                </div>
              </section>
            )
          }
        </div>
      </div>
    </div>
  </div>
  </main>
</Layout>

<style>
  .booking-page {
    padding-bottom: 3rem;
  }

  .booking-page__hero {
    background:
      linear-gradient(120deg, rgba(247, 249, 244, 0.96), rgba(232, 242, 227, 0.82)),
      var(--wb-surface);
    border-bottom: 1px solid var(--wb-border);
    color: var(--wb-text);
    padding: clamp(2rem, 5vw, 3.5rem) 0;
  }

  .booking-page__back {
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1.4rem;
    color: var(--wb-green-mid);
    font-size: 0.85rem;
    font-weight: 800;
    text-decoration: none;
    text-transform: uppercase;
  }

  .booking-page__back:hover {
    color: var(--wb-green-dark);
  }

  .booking-page__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--wb-green);
    font-size: 0.74rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .booking-page h1 {
    margin: 0;
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.25rem, 5vw, 4rem);
    letter-spacing: 0;
  }

  .booking-page__intro {
    max-width: 42rem;
    margin: 0.75rem 0 0;
    color: var(--wb-muted);
    font-size: 1rem;
  }

  .booking-page__venue-card,
  .booking-page__form-card {
    overflow: hidden;
    border: 1px solid var(--wb-border);
    border-radius: var(--wb-radius-lg);
    background: rgba(255, 255, 255, 0.88);
    box-shadow: var(--wb-shadow-md);
  }

  .booking-page__form-card {
    padding: clamp(1rem, 3vw, 2rem);
  }

  .booking-page__login-panel {
    border: 1px solid var(--wb-border);
    border-radius: var(--wb-radius-lg);
    background:
      radial-gradient(circle at top right, rgba(232, 242, 227, 0.98), transparent 16rem),
      rgba(255, 255, 255, 0.9);
    box-shadow: var(--wb-shadow-md);
    color: var(--wb-text);
    padding: clamp(1.5rem, 4vw, 2.35rem);
  }

  .booking-page__login-eyebrow {
    margin: 0 0 0.4rem;
    color: var(--wb-green);
    font-size: 0.74rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .booking-page__login-panel h2 {
    margin: 0;
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.85rem, 5vw, 2.65rem);
    letter-spacing: 0;
    line-height: 1.1;
  }

  .booking-page__login-message {
    max-width: 34rem;
    margin: 0.85rem 0 0;
    color: var(--wb-muted);
    font-size: 1rem;
    line-height: 1.6;
  }

  .booking-page__login-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.5rem;
  }

  .booking-page__login-button {
    display: inline-flex;
    min-height: 2.9rem;
    flex: 1 1 10rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: var(--wb-radius-md);
    font-size: 0.84rem;
    font-weight: 900;
    line-height: 1.2;
    padding: 0.85rem 1rem;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
    transition:
      background-color 0.2s ease,
      border-color 0.2s ease,
      box-shadow 0.2s ease,
      color 0.2s ease,
      transform 0.2s ease;
  }

  .booking-page__login-button:hover {
    transform: translateY(-1px);
  }

  .booking-page__login-button--primary {
    background: var(--wb-green);
    box-shadow: 0 12px 22px rgba(74, 124, 63, 0.18);
    color: #ffffff;
  }

  .booking-page__login-button--primary:hover {
    background: var(--wb-green-mid);
  }

  .booking-page__login-button--secondary {
    border-color: var(--wb-border);
    background: var(--wb-surface-soft);
    color: var(--wb-green-mid);
  }

  .booking-page__login-button--secondary:hover,
  .booking-page__login-button--ghost:hover {
    background: var(--wb-green-soft);
    color: var(--wb-green-dark);
  }

  .booking-page__login-button--ghost {
    border-color: transparent;
    background: transparent;
    color: var(--wb-green-mid);
  }

  .booking-page__card-title {
    margin: 0 0 1rem;
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: 1.45rem;
    letter-spacing: 0;
  }

  .booking-page__detail-row,
  .booking-page__detail-block {
    border-bottom: 1px solid var(--wb-border);
    padding-bottom: 1rem;
  }

  .booking-page__detail-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }

  .booking-page__detail-row span:first-child,
  .booking-page__detail-block span,
  .booking-page__about span {
    color: var(--wb-muted);
    font-size: 0.82rem;
    font-weight: 800;
    text-transform: uppercase;
  }

  .booking-page__price {
    color: var(--wb-warm);
    font-size: 1.35rem;
    font-weight: 900;
    white-space: nowrap;
  }

  .booking-page__detail-block p,
  .booking-page__about p {
    margin: 0.4rem 0 0;
    color: var(--wb-text);
    font-size: 0.95rem;
  }

  .booking-page__note {
    margin-top: 1.5rem;
    border-top: 1px solid var(--wb-border);
    padding-top: 1.25rem;
  }

  .booking-page__note p {
    margin: 0;
    color: var(--wb-muted);
    font-size: 0.8rem;
    text-align: center;
  }

  @media (max-width: 1023px) {
    .booking-page__venue-card {
      position: static;
    }
  }

  :global(html.dark) .booking-page__hero {
    background:
      radial-gradient(circle at 12% 0%, rgba(37, 56, 35, 0.74), transparent 28rem),
      var(--wb-surface) !important;
  }

  :global(html.dark) .booking-page__venue-card,
  :global(html.dark) .booking-page__form-card,
  :global(html.dark) .booking-page__login-panel {
    background: var(--wb-surface-raised) !important;
    border-color: var(--wb-border) !important;
  }

  :global(html.dark) .booking-page__login-button--secondary {
    background: var(--wb-surface-soft);
    border-color: var(--wb-border);
  }

  :global(html.dark) .booking-page__note,
  :global(html.dark) .booking-page__detail-row,
  :global(html.dark) .booking-page__detail-block {
    border-color: var(--wb-border) !important;
  }
</style>
