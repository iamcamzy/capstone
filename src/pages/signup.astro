---
import Layout from '../layouts/Layout.astro';
import ShowButton from '../components/showButton.astro';
---

<Layout title="Register">
  <div class="auth-page w-full min-h-[69vh] flex justify-center items-center py-12 px-4">
    <div id="formBox" class="auth-card w-full max-w-3xl h-auto ring-2 rounded-xl">
      <div
        id="formHeader"
        class="auth-card__header border-b w-full h-auto px-6 py-3 flex justify-between gap-4 items-center"
      >
        <h1 class="text-[2em] font-bold">Sign up for a new account</h1>
        <a
          href="/"
          class="auth-back flex justify-center items-center text-[1.2em] rounded-2xl py-1 px-5 ring-1"
          >Back</a
        >
      </div>

      <form id="register-form" novalidate class="px-5 py-10">
        <div
          class="signup-grid w-full h-auto grid grid-cols-12 grid-rows-4 items-center gap-5"
        >
          <label
            for="firstName"
            class="col-start-1 col-span-2 text-[1.2em] font-bold"
          >
            First Name:
          </label>
          <input
            type="text"
            name="firstName"
            id="firstName"
            required
            class="p-2 indent-4 rounded ring w-auto col-start-3 -col-end-4"
          />

          <label
            for="lastName"
            class="col-start-1 col-span-2 text-[1.2em] font-bold"
          >
            Last Name:
          </label>
          <input
            type="text"
            name="lastName"
            id="lastName"
            required
            class="p-2 indent-4 rounded ring w-auto col-start-3 -col-end-4"
          />

          <label
            for="email"
            class="col-start-1 col-span-2 text-[1.2em] font-bold"
          >
            Email:
          </label>
          <input
            type="email"
            name="email"
            id="email"
            required
            class="p-2 indent-4 rounded ring w-auto col-start-3 -col-end-4"
          />

          <label
            for="password"
            class="col-start-1 col-span-2 text-[1.2em] font-bold"
          >
            Password:
          </label>
          <input
            type="password"
            name="password"
            id="password"
            required
            class="p-2 indent-4 rounded ring w-auto col-start-3 -col-end-4"
          /><ShowButton />
        </div>
        <div
          class="mt-10
            w-full
            h-auto
            flex
            justify-center
            items-center"
        >
          <button
            type="submit"
            class="auth-submit max-w-[20ch] text-[2em] text-white font-bold rounded-2xl py-2 px-5 hover:cursor-pointer"
            >REGISTER</button
          >
        </div>
      </form>
      <p class="mt-2 flex justify-end py-2 px-5 gap-2">
        Already have an account?
        <a
          href="/signin"
          class="auth-link hover:pointer-cursor underline"
          >Sign in</a
        >
      </p>
      <!-- Inline error/notice banner -->
      <div id="signupNotice" class="hidden mx-5 mb-4 px-4 py-3 rounded-lg text-sm font-semibold flex items-center gap-2"></div>
    </div>
  </div>
</Layout>
<script>
  const form = document.getElementById('register-form') as HTMLFormElement | null;
  const noticeEl = document.getElementById('signupNotice');

  function showNotice(msg: string, type: 'error' | 'success') {
    if (!noticeEl) return;
    noticeEl.className = 'mx-5 mb-4 px-4 py-3 rounded-lg text-sm font-semibold flex items-center gap-2 '
      + (type === 'success' ? 'bg-green-100 text-green-800' : 'bg-red-100 text-red-800');
    noticeEl.innerHTML = (type === 'success' ? '✅ ' : '❌ ') + msg;
    noticeEl.classList.remove('hidden');
  }

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (noticeEl) noticeEl.classList.add('hidden');

    const formData = new FormData(form);
    const firstName = formData.get('firstName')?.toString().trim();
    const lastName  = formData.get('lastName')?.toString().trim();
    const email     = formData.get('email')?.toString().trim();
    const password  = formData.get('password')?.toString();

    if (!firstName || !lastName || !email || !password) {
      showNotice('Please fill in all fields.', 'error');
      return;
    }

    try {
      const res = await fetch('/api/auth/signup', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, password, firstName, lastName }),
        redirect: 'follow',
      });

      if (res.redirected) {
        window.location.href = res.url;
        return;
      }

      if (res.ok) {
        window.location.href = '/dashboard';
      } else {
        const data = await res.json().catch(() => ({}));
        showNotice('Signup failed: ' + (data.error ?? 'Please try again.'), 'error');
      }
    } catch {
      showNotice('Something went wrong. Please try again.', 'error');
    }
  });
</script>

<style>
  .auth-page {
    background:
      radial-gradient(circle at 12% 8%, rgba(232, 242, 227, 0.78), transparent 26rem),
      var(--wb-surface);
  }

  .auth-card {
    overflow: hidden;
    border: 1px solid var(--wb-border);
    background: var(--wb-surface-raised);
    box-shadow: var(--wb-shadow-md);
    color: var(--wb-text);
  }

  .auth-card__header {
    border-color: var(--wb-border);
    background: var(--wb-surface-soft);
  }

  .auth-card h1 {
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.45rem, 4vw, 2rem);
    letter-spacing: 0;
    line-height: 1.15;
  }

  .auth-card label {
    color: var(--wb-green-dark);
  }

  .auth-card input {
    border: 1px solid var(--wb-border);
    background: #fff;
    color: var(--wb-text);
  }

  .auth-card input:focus {
    border-color: var(--wb-green);
    box-shadow: 0 0 0 4px rgba(74, 124, 63, 0.12);
    outline: 0;
  }

  .auth-back {
    border-color: rgba(154, 74, 54, 0.32);
    background: #9a4a36;
    color: #fff;
    text-decoration: none;
  }

  .auth-submit {
    background: var(--wb-green);
  }

  .auth-submit:hover {
    background: var(--wb-green-mid);
  }

  .auth-link {
    color: var(--wb-green-mid);
    font-weight: 700;
  }

  :global(html.dark) .auth-page {
    background:
      radial-gradient(circle at 12% 8%, rgba(37, 56, 35, 0.72), transparent 26rem),
      var(--wb-surface);
  }

  :global(html.dark) .auth-card input {
    background: var(--wb-surface-soft) !important;
    color: var(--wb-text) !important;
  }

  @media (max-width: 720px) {
    .auth-card__header {
      align-items: flex-start;
      flex-direction: column;
    }

    .signup-grid {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0.85rem;
    }

    .signup-grid label,
    .signup-grid input {
      grid-column: auto;
      width: 100%;
    }

    .auth-submit {
      width: 100%;
      max-width: none;
      font-size: 1.2rem;
    }
  }
</style>
