---
import '../styles/global.css';
import Layout from '../layouts/Layout.astro';
---

<Layout>
  <div class="gallery-page">
    <div class="gallery-header">
      <h1>Our Gallery</h1>
      <p>A glimpse into the beauty of Woodberry Resorts & Events</p>
    </div>

    <div class="gallery-grid">
      <div class="gallery-item tall">
        <img src="/woodberyPics/pool_and_house.jpg" alt="Pool and house" />
        <div class="gallery-overlay"><span>Pool & House</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/banquet_1.jpg" alt="Banquet hall" />
        <div class="gallery-overlay"><span>Banquet Hall</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/pool_1.jpg" alt="Pool" />
        <div class="gallery-overlay"><span>Pool</span></div>
      </div>
      <div class="gallery-item wide">
        <img src="/woodberyPics/stage_1.jpg" alt="Stage" />
        <div class="gallery-overlay"><span>Stage</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/entrance_1.jpg" alt="Entrance" />
        <div class="gallery-overlay"><span>Entrance</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/tables_1.jpg" alt="Tables setup" />
        <div class="gallery-overlay"><span>Event Setup</span></div>
      </div>
      <div class="gallery-item tall">
        <img src="/woodberyPics/tree_house.jpg" alt="Tree house" />
        <div class="gallery-overlay"><span>Tree House</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/afternoon_pool_1.jpg" alt="Afternoon pool" />
        <div class="gallery-overlay"><span>Afternoon Pool</span></div>
      </div>
      <div class="gallery-item wide">
        <img src="/woodberyPics/stage_2.jpg" alt="Decorated stage" />
        <div class="gallery-overlay"><span>Decorated Stage</span></div>
      </div>
      <div class="gallery-item">
        <img src="/woodberyPics/entrance_2.jpg" alt="Resort entrance" />
        <div class="gallery-overlay"><span>Resort Entrance</span></div>
      </div>
    </div>
  </div>

  <div id="galleryLightbox" class="gallery-lightbox" aria-hidden="true">
    <img id="galleryLightboxImg" src="" alt="" />
    <p id="galleryLightboxCaption" class="gallery-lightbox-caption"></p>
  </div>
</Layout>

<style>
  .gallery-page {
    max-width: 1200px;
    margin: 0 auto;
    padding: 2.5rem 2rem 4rem;
  }

  .gallery-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .gallery-header h1 {
    font-family: Georgia, 'Times New Roman', serif;
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 800;
    color: #1a2e10;
    margin-bottom: 0.5rem;
  }

  .gallery-header p {
    color: #4a7c3f;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.04em;
  }

  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    grid-auto-rows: 220px;
    gap: 0.8rem;
  }

  .gallery-item {
    position: relative;
    overflow: hidden;
    border-radius: 14px;
    cursor: pointer;
  }

  .gallery-item.tall {
    grid-row: span 2;
  }

  .gallery-item.wide {
    grid-column: span 2;
  }

  .gallery-item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
    display: block;
  }

  .gallery-item:hover img {
    transform: scale(1.06);
  }

  .gallery-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to top, rgba(26,46,16,0.65) 0%, transparent 50%);
    display: flex;
    align-items: flex-end;
    padding: 1rem 1.2rem;
    opacity: 0;
    transition: opacity 0.3s ease;
  }

  .gallery-item:hover .gallery-overlay {
    opacity: 1;
  }

  .gallery-overlay span {
    color: white;
    font-weight: 600;
    font-size: 0.95rem;
    letter-spacing: 0.04em;
  }

  @media (max-width: 768px) {
    .gallery-grid {
      grid-template-columns: repeat(2, 1fr);
      grid-auto-rows: 180px;
    }
    .gallery-item.wide {
      grid-column: span 2;
    }
  }

  @media (max-width: 480px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      grid-auto-rows: 200px;
    }
    .gallery-item.tall,
    .gallery-item.wide {
      grid-column: span 1;
      grid-row: span 1;
    }
  }

  .gallery-lightbox {
    position: fixed;
    inset: 0;
    z-index: 1000;
    display: none;
    align-items: center;
    justify-content: center;
    padding: 4.5rem 1.5rem 2rem;
    background: rgba(0,0,0,0.85);
  }

  .gallery-lightbox.open {
    display: flex;
  }

  .gallery-lightbox img {
    max-width: min(94vw, 1200px);
    max-height: 78vh;
    object-fit: contain;
    border-radius: 14px;
    box-shadow: 0 20px 60px rgba(0,0,0,0.35);
    transition: transform 0.2s ease;
    cursor: zoom-in;
  }

  .gallery-lightbox.zoomed img {
    transform: scale(1.65);
    cursor: zoom-out;
  }

  .gallery-lightbox-close,
  .gallery-lightbox-zoom {
    position: fixed;
    top: 1rem;
    border: none;
    border-radius: 999px;
    background: rgba(255,255,255,0.92);
    color: #1f2937;
    font-weight: 800;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(0,0,0,0.25);
  }

  .gallery-lightbox-close {
    right: 1rem;
    width: 44px;
    height: 44px;
    font-size: 2rem;
    line-height: 1;
  }

  .gallery-lightbox-zoom {
    right: 4.5rem;
    padding: 0.8rem 1rem;
    font-size: 0.85rem;
  }

  .gallery-lightbox-caption {
    position: fixed;
    bottom: 1.2rem;
    left: 50%;
    transform: translateX(-50%);
    color: white;
    font-weight: 700;
    letter-spacing: 0.04em;
    text-align: center;
  }

</style>

<script>
  const lightbox = document.getElementById('galleryLightbox');
  const lightboxImg = document.getElementById('galleryLightboxImg') as HTMLImageElement | null;
  const lightboxCaption = document.getElementById('galleryLightboxCaption');
  const closeBtn = document.getElementById('galleryLightboxClose');
  const zoomBtn = document.getElementById('galleryLightboxZoom');

  function closeGalleryLightbox() {
    lightbox?.classList.remove('open', 'zoomed');
    lightbox?.setAttribute('aria-hidden', 'true');
    if (zoomBtn) zoomBtn.textContent = 'Zoom In';
  }

  function toggleGalleryZoom() {
    if (!lightbox) return;
    const zoomed = lightbox.classList.toggle('zoomed');
    if (zoomBtn) zoomBtn.textContent = zoomed ? 'Zoom Out' : 'Zoom In';
  }

  document.querySelectorAll<HTMLElement>('.gallery-item').forEach((item) => {
    item.addEventListener('click', () => {
      const img = item.querySelector('img') as HTMLImageElement | null;
      const caption = item.querySelector('.gallery-overlay span')?.textContent ?? img?.alt ?? '';
      if (!img || !lightboxImg || !lightbox) return;
      lightboxImg.src = img.src;
      lightboxImg.alt = img.alt;
      if (lightboxCaption) lightboxCaption.textContent = caption;
      lightbox.classList.add('open');
      lightbox.classList.remove('zoomed');
      lightbox.setAttribute('aria-hidden', 'false');
      if (zoomBtn) zoomBtn.textContent = 'Zoom In';
    });
  });

  closeBtn?.addEventListener('click', closeGalleryLightbox);
  zoomBtn?.addEventListener('click', toggleGalleryZoom);
  lightboxImg?.addEventListener('click', toggleGalleryZoom);
  lightbox?.addEventListener('click', (event) => {
    if (event.target === lightbox) closeGalleryLightbox();
  });
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape') closeGalleryLightbox();
  });
</script>
