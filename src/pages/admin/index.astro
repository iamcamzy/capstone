function formatMoney(value: unknown): string {
  const amount = Number(value ?? 0);
  return amount ? '₱' + amount.toLocaleString() : '—';
}

function formatBookingItems(items: any): string {
  if (!Array.isArray(items) || items.length === 0) return '—';
  return items.map((item: any) => {
    const suffix = item.hours ? ` (${item.hours} hr, ${formatMoney(item.amount)})` : item.amount ? ` (${formatMoney(item.amount)})` : '';
    return `${item.label ?? item.key}${suffix}`;
  }).join(', ');
}

function formatInclusions(value: any): string {
  if (!value) return '—';
  if (Array.isArray(value)) return value.map((item: any) => item.label ?? item).join(', ');
  if (Array.isArray(value.included)) return value.included.join(', ');
  return '—';
}

