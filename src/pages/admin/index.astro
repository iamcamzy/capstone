      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">Package Details</p>
        <div class="grid grid-cols-2 gap-x-6 gap-y-3 text-sm">
          <div class="col-span-2"><span class="text-gray-400">Inclusions</span><p id="bd-inclusions" class="font-semibold mt-0.5"></p></div>
          <div><span class="text-gray-400">Rooms</span><p id="bd-rooms" class="font-semibold mt-0.5"></p></div>
          <div><span class="text-gray-400">Add-ons</span><p id="bd-addons" class="font-semibold mt-0.5"></p></div>
          <div><span class="text-gray-400">Extensions</span><p id="bd-extensions" class="font-semibold mt-0.5"></p></div>
          <div><span class="text-gray-400">Corkage</span><p id="bd-corkage" class="font-semibold mt-0.5"></p></div>
          <div class="col-span-2"><span class="text-gray-400">Caterer</span><p id="bd-caterer" class="font-semibold mt-0.5"></p></div>
        </div>
      </div>

      <!-- Special requests -->
      <div id="bd-requests-wrap">
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-2">Special Requests</p>
        <p id="bd-requests" class="text-sm text-gray-700 bg-gray-50 rounded-lg px-4 py-3 italic"></p>
      </div>

      <!-- Timestamps -->
      <div>
        <p class="text-xs font-bold uppercase tracking-widest text-gray-400 mb-3">Timeline</p>
        <div class="grid grid-cols-2 gap-x-6 gap-y-2 text-sm">
          <div><span class="text-gray-400">Submitted</span><p id="bd-created" class="font-semibold mt-0.5"></p></div>
          <div><span class="text-gray-400">Last Updated</span><p id="bd-updated" class="font-semibold mt-0.5"></p></div>
          <div id="bd-confirmed-wrap"><span class="text-gray-400">Booked At</span><p id="bd-confirmed" class="font-semibold mt-0.5 text-green-600"></p></div>
          <div id="bd-cancelled-wrap"><span class="text-gray-400">Cancelled At</span><p id="bd-cancelled" class="font-semibold mt-0.5 text-red-500"></p></div>
          <div id="bd-rescheduled-wrap"><span class="text-gray-400">Rescheduled At</span><p id="bd-rescheduled" class="font-semibold mt-0.5 text-purple-600"></p></div>
        </div>
      </div>

    </div>

    <!-- Action bar -->
    <div id="bd-actions" class="sticky bottom-0 bg-white px-7 py-4 border-t border-gray-100 flex flex-wrap gap-3 z-10"></div>
  </div>
</div>

<!-- CUSTOM CONFIRM DIALOG (replaces all browser confirm() popups) -->
<div id="confirmDialog" class="hidden fixed inset-0 z-[60] flex items-center justify-center" style="background:rgba(0,0,0,0.55);">
  <div class="bg-white rounded-2xl shadow-2xl w-full max-w-sm mx-4 overflow-hidden">
    <!-- Icon + header -->
    <div id="confirmDialogHeader" class="px-6 pt-6 pb-4 flex flex-col items-center text-center">
      <div id="confirmDialogIcon" class="w-14 h-14 rounded-full flex items-center justify-center text-2xl mb-3"></div>
      <h3 id="confirmDialogTitle" class="text-lg font-black" style="color:var(--jet-primary);"></h3>
      <p id="confirmDialogMessage" class="text-sm text-gray-500 mt-1"></p>
    </div>
    <!-- Buttons -->
    <div class="px-6 pb-6 flex gap-3">
      <button id="confirmDialogCancel" class="flex-1 py-2.5 rounded-xl border-2 font-semibold text-sm transition hover:bg-gray-50" style="border-color:#d1d5db;color:#374151;">
        Cancel
      </button>
      <button id="confirmDialogOk" class="flex-1 py-2.5 rounded-xl text-white font-semibold text-sm transition hover:opacity-90">
        Confirm
      </button>
    </div>
  </div>
</div>

<!-- RESCHEDULE MODAL -->
<div id="rescheduleModal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
    <h3 class="text-xl font-bold mb-5" style="color:var(--jet-primary);">Reschedule Booking</h3>
    <input id="rescheduleBookingId" type="hidden" />
    <div class="space-y-4">
      <div><label class="block text-sm font-semibold mb-1">New Event Date</label><input type="date" id="rescheduleEventDate" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      <div><label class="block text-sm font-semibold mb-1">New Check-in *</label><input type="date" id="rescheduleStart" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" required /></div>
      <div><label class="block text-sm font-semibold mb-1">New Check-out *</label><input type="date" id="rescheduleEnd" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" required /></div>
      <p id="rescheduleOverrideWarning" class="hidden rounded-lg border px-3 py-2 text-sm font-semibold"></p>
    </div>
    <div class="flex gap-3 mt-6">
      <button onclick="closeReschedule()" class="flex-1 py-2 rounded-lg border-2 font-semibold" style="border-color:var(--lion-light);">Cancel</button>
      <button onclick="submitReschedule()" class="flex-1 py-2 rounded-lg text-white font-semibold" style="background:var(--butterscotch-primary);">Reschedule</button>
    </div>
  </div>
</div>

<!-- CONTRACT SIGNING SCHEDULE MODAL -->
<div id="contractSigningScheduleModal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-md mx-4 p-6">
    <h3 class="text-xl font-bold mb-2" style="color:var(--jet-primary);">Contract Signing Schedule</h3>
    <p class="text-sm text-gray-500 mb-5">Set the date and time the customer should visit for contract signing.</p>
    <input id="contractSigningBookingId" type="hidden" />
    <div class="space-y-4">
      <div>
        <label class="block text-sm font-semibold mb-1" for="contractSigningDate">Contract-signing date *</label>
        <input type="date" id="contractSigningDate" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" required />
      </div>
      <div>
        <label class="block text-sm font-semibold mb-1" for="contractSigningTime">Contract-signing time *</label>
        <input type="time" id="contractSigningTime" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" required />
      </div>
    </div>
    <div class="flex gap-3 mt-6">
      <button onclick="closeContractSigningSchedule()" class="flex-1 py-2 rounded-lg border-2 font-semibold" style="border-color:var(--lion-light);">Cancel</button>
      <button onclick="submitContractSigningSchedule()" class="flex-1 py-2 rounded-lg text-white font-semibold" style="background:var(--butterscotch-primary);">Save Schedule</button>
    </div>
  </div>
</div>

<!-- VENUE MODAL -->
<div id="venueModal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4 p-6 max-h-[90vh] overflow-y-auto">
    <h3 id="venueModalTitle" class="text-xl font-bold mb-5" style="color:var(--jet-primary);">Add Venue</h3>
    <input id="venueId" type="hidden" />
    <div class="space-y-4">
      <div><label class="block text-sm font-semibold mb-1">Name *</label><input type="text" id="venueName" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      <div><label class="block text-sm font-semibold mb-1">Description</label><textarea id="venueDesc" rows="2" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none resize-none"></textarea></div>
      <div><label class="block text-sm font-semibold mb-1">Location</label><input type="text" id="venueLocation" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-semibold mb-1">Capacity</label><input type="number" id="venueCapacity" min="1" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
        <div><label class="block text-sm font-semibold mb-1">Price/Night (₱) *</label><input type="number" id="venuePrice" min="0" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      </div>
      <div><label class="block text-sm font-semibold mb-1">Image URL</label><input type="text" id="venueImage" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
    </div>
    <div class="flex gap-3 mt-6">
      <button onclick="closeVenueModal()" class="flex-1 py-2 rounded-lg border-2 font-semibold" style="border-color:var(--lion-light);">Cancel</button>
      <button onclick="submitVenue()" class="flex-1 py-2 rounded-lg text-white font-semibold" style="background:var(--butterscotch-primary);">Save</button>
    </div>
  </div>
</div>

<!-- PACKAGE MODAL -->
<div id="packageModal" class="hidden fixed inset-0 z-50 flex items-center justify-center" style="background:rgba(0,0,0,0.5);">
  <div class="bg-white rounded-xl shadow-2xl w-full max-w-lg mx-4 p-6">
    <h3 id="packageModalTitle" class="text-xl font-bold mb-5" style="color:var(--jet-primary);">Add Package</h3>
    <input id="packageId" type="hidden" />
    <div class="space-y-4">
      <div><label class="block text-sm font-semibold mb-1">Name *</label><input type="text" id="packageName" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      <div><label class="block text-sm font-semibold mb-1">Description</label><textarea id="packageDesc" rows="2" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none resize-none"></textarea></div>
      <div class="grid grid-cols-2 gap-4">
        <div><label class="block text-sm font-semibold mb-1">Price (₱) *</label><input type="number" id="packagePrice" min="0" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
        <div><label class="block text-sm font-semibold mb-1">Max Pax</label><input type="number" id="packageMaxPax" min="1" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none" /></div>
      </div>
      <div><label class="block text-sm font-semibold mb-1">Inclusions</label><textarea id="packageInclusions" rows="2" class="w-full p-2 rounded-lg border border-gray-200 focus:outline-none resize-none" placeholder="e.g. Tables, Chairs, Sound System"></textarea></div>
    </div>
    <div class="flex gap-3 mt-6">
      <button onclick="closePackageModal()" class="flex-1 py-2 rounded-lg border-2 font-semibold" style="border-color:var(--lion-light);">Cancel</button>
      <button onclick="submitPackage()" class="flex-1 py-2 rounded-lg text-white font-semibold" style="background:var(--butterscotch-primary);">Save</button>
    </div>
  </div>
</div>

<!-- TOAST -->
<div id="toast" class="hidden fixed bottom-6 right-6 z-50 px-5 py-3 rounded-xl text-white text-sm font-semibold shadow-lg"></div>
</Layout>

