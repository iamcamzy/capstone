// ── ADMIN AVAILABILITY CALENDAR ───────────────────────────────────────────────
const admMonths = ['January','February','March','April','May','June',
                   'July','August','September','October','November','December'];
let admYear  = new Date().getFullYear();
let admMonth = new Date().getMonth(); // 0-indexed
const admCache: Record<string, any[]> = {};

async function admFetchBookings(year: number, month: number): Promise<any[]> {
  const key = `${year}-${month}`;
  if (admCache[key]) return admCache[key];
  const loading = document.getElementById('adm-cal-loading')!;
  loading.style.display = 'block';
  try {
    const res  = await fetch(`/api/bookings/availability?year=${year}&month=${month + 1}`);
    const json = await res.json();
    admCache[key] = json.bookings ?? [];
    return admCache[key];
  } catch { return []; }
  finally { loading.style.display = 'none'; }
}

// Build a map of dateISO -> bookings[]
function admBuildDateMap(bookings: any[]): Record<string, any[]> {
  const map: Record<string, any[]> = {};
  for (const b of bookings) {
    const start = new Date((b.start_date ?? b.event_date) + 'T00:00:00');
    const end   = new Date((b.end_date   ?? b.event_date) + 'T00:00:00');
    for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
      const iso = d.toISOString().split('T')[0];
      if (!map[iso]) map[iso] = [];
      map[iso].push(b);
    }
  }
  return map;
}

const STATUS_CELL: Record<string, { bg: string; ring: string; text: string }> = {
  booked:   { bg: '#f0fdf4', ring: '#22c55e', text: '#15803d' },
  contract_signing: { bg: '#eff6ff', ring: '#3b82f6', text: '#1d4ed8' },
  pending:     { bg: '#fffbeb', ring: '#f59e0b', text: '#92400e' },
  rescheduled: { bg: '#f3e8ff', ring: '#a855f7', text: '#6b21a8' },
  completed: { bg: '#f8fafc', ring: '#64748b', text: '#334155' },
};

async function admRenderCalendar() {
  const label = document.getElementById('adm-month-label')!;
  label.textContent = `${admMonths[admMonth]} ${admYear}`;
  const grid  = document.getElementById('adm-cal-grid')!;
  grid.innerHTML = '';

  const bookings = await admFetchBookings(admYear, admMonth);
  const dateMap  = admBuildDateMap(bookings);

  const firstDow  = new Date(admYear, admMonth, 1).getDay();
  const offset    = (firstDow + 6) % 7;
  const daysInMo  = new Date(admYear, admMonth + 1, 0).getDate();
  const total     = Math.ceil((offset + daysInMo) / 7) * 7;
  const todayISO  = new Date().toISOString().split('T')[0];

  for (let i = 0; i < total; i++) {
    const dayNum = i - offset + 1;
    const cell   = document.createElement('div');
    cell.style.cssText = 'min-height:90px;padding:6px;border:1px solid #f3f4f6;position:relative;cursor:pointer;transition:background 0.15s;';

    if (dayNum < 1 || dayNum > daysInMo) {
      cell.style.background = '#fafafa';
      cell.style.cursor = 'default';
    } else {
      const iso = `${admYear}-${String(admMonth+1).padStart(2,'0')}-${String(dayNum).padStart(2,'0')}`;
      const dayBookings = dateMap[iso] ?? [];
      const isPast  = iso < todayISO;
      const isToday = iso === todayISO;

      cell.style.background = isPast ? '#fafafa' : '#fff';
      if (isToday) cell.style.background = '#f0fdf4';

      // Day number
      const num = document.createElement('div');
      num.textContent = String(dayNum);
      num.style.cssText = `font-size:0.8rem;font-weight:${isToday?'800':'600'};color:${isToday?'#2d5a27':'#374151'};margin-bottom:3px;`;
      cell.appendChild(num);

      // Booking chips (max 3)
      const shown = dayBookings.slice(0, 3);
      for (const b of shown) {
        const s = STATUS_CELL[b.status] ?? STATUS_CELL.pending;
        const chip = document.createElement('div');
        chip.textContent = statusLabel(b.status);
        chip.style.cssText = `font-size:0.65rem;font-weight:700;padding:1px 5px;border-radius:4px;background:${s.bg};color:${s.text};outline:1px solid ${s.ring};margin-bottom:2px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;`;
        cell.appendChild(chip);
      }
      if (dayBookings.length > 3) {
        const more = document.createElement('div');
        more.textContent = `+${dayBookings.length - 3} more`;
        more.style.cssText = 'font-size:0.6rem;color:#9ca3af;font-weight:600;';
        cell.appendChild(more);
      }

      cell.addEventListener('mouseenter', () => { if (!isPast) cell.style.background = '#f8faff'; });
      cell.addEventListener('mouseleave', () => { cell.style.background = isToday ? '#f0fdf4' : isPast ? '#fafafa' : '#fff'; });
      cell.addEventListener('click', () => admShowDayDetail(iso, dayBookings));
    }

    grid.appendChild(cell);
  }
}

function admShowDayDetail(iso: string, bookings: any[]) {
  const panel   = document.getElementById('adm-day-detail')!;
  const dateEl  = document.getElementById('adm-detail-date')!;
  const content = document.getElementById('adm-detail-content')!;

  const formatted = new Date(iso + 'T00:00:00').toLocaleDateString('en-PH', { weekday:'long', month:'long', day:'numeric', year:'numeric' });
  dateEl.textContent = formatted;
  panel.classList.remove('hidden');

  if (bookings.length === 0) {
    content.innerHTML = '<p class="text-gray-400 py-4 text-center">No bookings on this date — it\'s available! ✅</p>';
    return;
  }

  // Fetch full booking data from window.__allBookings for names
  const allB: any[] = (window as any).__allBookings ?? [];
  const byId: Record<string, any> = {};
  allB.forEach((b: any) => { byId[b.id] = b; });

  content.innerHTML = bookings.map(b => {
    const full = byId[b.id] ?? b;
    const s = STATUS_CELL[b.status] ?? STATUS_CELL.pending;
    const actionBtns = b.status === 'pending'
      ? `<button onclick="confirmBooking('${b.id}')" style="padding:4px 10px;border-radius:6px;background:#10b981;color:white;font-size:0.72rem;font-weight:700;border:none;cursor:pointer;">✓ Confirm</button>
         <button onclick="cancelBooking('${b.id}')" style="padding:4px 10px;border-radius:6px;background:#ef4444;color:white;font-size:0.72rem;font-weight:700;border:none;cursor:pointer;">✕ Cancel</button>`
      : b.status === 'booked'
      ? `<button onclick="cancelBooking('${b.id}')" style="padding:4px 10px;border-radius:6px;background:#ef4444;color:white;font-size:0.72rem;font-weight:700;border:none;cursor:pointer;">✕ Cancel</button>`
      : '';
    return `<div style="padding:12px 16px;border-radius:12px;background:${s.bg};outline:1.5px solid ${s.ring};display:flex;justify-content:space-between;align-items:flex-start;gap:12px;flex-wrap:wrap;">
      <div>
        <div style="font-weight:700;color:${s.text};font-size:0.85rem;">${full.full_name ?? full.venueName ?? 'Guest'}</div>
        <div style="color:#6b7280;font-size:0.75rem;margin-top:2px;">${full.venueName ?? ''} ${full.event_type ? '· ' + full.event_type : ''}</div>
        <div style="color:#9ca3af;font-size:0.72rem;margin-top:2px;">${new Date(b.start_date+'T00:00:00').toLocaleDateString('en-PH',{month:'short',day:'numeric'})} → ${new Date(b.end_date+'T00:00:00').toLocaleDateString('en-PH',{month:'short',day:'numeric'})}</div>
      </div>
      <div style="display:flex;flex-direction:column;align-items:flex-end;gap:5px;">
        <span style="font-size:0.7rem;font-weight:700;padding:2px 8px;border-radius:9999px;background:${s.bg};color:${s.text};outline:1px solid ${s.ring};">${statusLabel(b.status)}</span>
        <div style="display:flex;gap:4px;flex-wrap:wrap;">${actionBtns}</div>
      </div>
    </div>`;
  }).join('');
}

document.getElementById('adm-detail-close')?.addEventListener('click', () => {
  document.getElementById('adm-day-detail')?.classList.add('hidden');
});
document.getElementById('adm-prev-month')?.addEventListener('click', () => {
  if (admMonth === 0) { admMonth = 11; admYear--; } else { admMonth--; }
  admRenderCalendar();
  document.getElementById('adm-day-detail')?.classList.add('hidden');
});
document.getElementById('adm-next-month')?.addEventListener('click', () => {
  if (admMonth === 11) { admMonth = 0; admYear++; } else { admMonth++; }
  admRenderCalendar();
  document.getElementById('adm-day-detail')?.classList.add('hidden');
});

// Render calendar when the tab becomes active
const _origSwitchTab = (window as any).switchTab;
document.querySelectorAll<HTMLElement>('.nav-btn[data-tab="calendar"]').forEach(btn => {
  btn.addEventListener('click', () => admRenderCalendar());
});
