---
import Layout from '../../layouts/Layout.astro';
import { requireAuth } from '../../lib/auth';
import { supabase, supabaseAdmin } from '../../lib/supabase';
import { BOOKING_STATUS_LABELS, normalizeBookingStatus } from '../../lib/bookingStatus';

export const prerender = false;

const user = await requireAuth(Astro.cookies);
if (!user) return Astro.redirect('/signin');

// Use service role client so RLS never blocks the role check
const adminClient = supabaseAdmin ?? supabase;
const { data: profile } = await adminClient
  .from('admins')
  .select('first_name, last_name')
  .eq('id', user.id)
  .single();

// Not in admins table = not an admin
if (!profile) return Astro.redirect('/dashboard');

const { data: bookings } = await adminClient
  .from('bookings')
  .select('id, full_name, phone, pax, event_date, start_date, end_date, event_type, status, total_price, created_at, updated_at, confirmed_at, cancelled_at, rescheduled_at, special_requests, venue_id, user_id, package_id')
  .order('created_at', { ascending: false })
  .limit(200);

// Separately fetch venue names for each booking
const venueIds = [...new Set((bookings ?? []).map(b => b.venue_id).filter(Boolean))];
const { data: venueMap } = venueIds.length > 0
  ? await adminClient.from('venues').select('id, name').in('id', venueIds)
  : { data: [] };
const venueById: Record<string, string> = {};
(venueMap ?? []).forEach((v: any) => { venueById[v.id] = v.name; });

const packageIds = [...new Set((bookings ?? []).map(b => b.package_id).filter((id): id is string => id !== null && id !== undefined))];
const { data: pkgMap } = packageIds.length > 0
  ? await adminClient.from('packages').select('id, name').in('id', packageIds)
  : { data: [] };
const packageById: Record<string, string> = {};
(pkgMap ?? []).forEach((p: any) => { packageById[p.id] = p.name; });

const userIds = [...new Set((bookings ?? []).map(b => b.user_id).filter(Boolean))];
const { data: userMap } = userIds.length > 0
  ? await adminClient.from('users').select('id, first_name, last_name, email').in('id', userIds)
  : { data: [] };
const userById: Record<string, any> = {};
(userMap ?? []).forEach((u: any) => { userById[u.id] = u; });

// Attach names to bookings
const enrichedBookings = (bookings ?? []).map(b => ({
  ...b,
  status: normalizeBookingStatus(b.status),
  venueName: venueById[b.venue_id] ?? '—',
  packageName: b.package_id ? (packageById[b.package_id] ?? '—') : null,
  userName: userById[b.user_id] ?? null,
}));

const statusLabels = BOOKING_STATUS_LABELS;

const { data: venues } = await adminClient.from('venues').select('*').order('name');
const { data: packages } = await adminClient.from('packages').select('*').order('price');
const { data: rawReviews } = await adminClient
  .from('reviews')
  .select('id, rating, comment, created_at, user_id, booking_id')
  .order('created_at', { ascending: false })
  .limit(100);

const reviewUserIds = [...new Set((rawReviews ?? []).map((r: any) => r.user_id).filter(Boolean))];
const { data: reviewUsers } = reviewUserIds.length > 0
  ? await adminClient.from('users').select('id, first_name, last_name, email').in('id', reviewUserIds)
  : { data: [] };
const reviewUserById: Record<string, any> = {};
(reviewUsers ?? []).forEach((u: any) => { reviewUserById[u.id] = u; });

const reviewBookingIds = [...new Set((rawReviews ?? []).map((r: any) => r.booking_id).filter(Boolean))];
const { data: reviewBookings } = reviewBookingIds.length > 0
  ? await adminClient.from('bookings').select('id, event_date, venue_id').in('id', reviewBookingIds)
  : { data: [] };
const reviewBookingById: Record<string, any> = {};
(reviewBookings ?? []).forEach((b: any) => { reviewBookingById[b.id] = b; });

const reviews = (rawReviews ?? []).map((r: any) => ({
  ...r,
  reviewUser: reviewUserById[r.user_id] ?? null,
  reviewBooking: reviewBookingById[r.booking_id] ?? null,
  reviewVenueName: reviewBookingById[r.booking_id]?.venue_id ? (venueById[reviewBookingById[r.booking_id].venue_id] ?? '—') : '—',
}));

const { data: allCustomers } = await adminClient
  .from('customers')
  .select('id, email, first_name, last_name, created_at')
  .order('created_at', { ascending: false });

const { data: allAdmins } = await adminClient
  .from('admins')
  .select('id, email, first_name, last_name, created_at')
  .order('created_at', { ascending: false });

const stats = {
  total:       enrichedBookings.length,
  pending:     enrichedBookings.filter(b => b.status === 'pending').length,
  contractSigning: enrichedBookings.filter(b => b.status === 'contract_signing').length,
  booked:     enrichedBookings.filter(b => b.status === 'booked').length,
  cancelled:   enrichedBookings.filter(b => b.status === 'cancelled').length,
  rescheduled: enrichedBookings.filter(b => b.status === 'rescheduled').length,
  completed: enrichedBookings.filter(b => b.status === 'completed').length,
  revenue:     enrichedBookings.filter(b => b.status === 'booked' || b.status === 'completed')
                               .reduce((s, b) => s + (Number(b.total_price) ?? 0), 0),
  avgPax: (() => {
    const w = enrichedBookings.filter(b => b.pax && (b.status === 'booked' || b.status === 'completed'));
    return w.length ? Math.round(w.reduce((s,b) => s + (b.pax ?? 0), 0) / w.length) : 0;
  })(),
};

const adminName = profile.first_name
  ? `${profile.first_name} ${profile.last_name ?? ''}`.trim()
  : user.email;
---

<Layout title="Admin Dashboard">
<div id="admin-root" class="min-h-screen" style="background:#f5f3f0;">

  <!-- SIDEBAR -->
  <aside id="sidebar" class="fixed top-0 left-0 h-full w-64 z-50 flex flex-col shadow-xl" style="background:var(--jet-primary);color:white;">
    <div class="px-6 py-5 border-b border-white/10">
      <p class="text-xs font-semibold uppercase tracking-widest mb-1" style="color:rgba(255,255,255,0.55);">Admin Panel</p>
      <p class="font-bold text-lg truncate" style="color:var(--butterscotch-primary);">{adminName}</p>
      <p class="text-xs truncate" style="color:rgba(255,255,255,0.65);">{user.email}</p>
    </div>
    <nav class="flex-1 px-3 py-4 space-y-1 overflow-y-auto">
      {[
        { id:'dashboard', icon:'📊', label:'Dashboard'  },
        { id:'bookings',  icon:'📅', label:'Bookings'   },
        { id:'venues',    icon:'🏖️', label:'Venues'     },
        { id:'packages',  icon:'📦', label:'Packages'   },
        { id:'reviews',   icon:'⭐', label:'Reviews'    },
        { id:'users',     icon:'👥', label:'Users'      },
        { id:'reports',   icon:'📈', label:'Reports'    },
        { id:'calendar',  icon:'🗓️', label:'Availability'},
      ].map(nav => (
        <button data-tab={nav.id} class="nav-btn w-full text-left px-4 py-2.5 rounded-lg flex items-center gap-3 text-sm font-medium transition-all hover:bg-white/10">
          <span>{nav.icon}</span><span>{nav.label}</span>
        </button>
      ))}
    </nav>
    <div class="px-4 py-4 border-t border-white/10">
      <a href="/dashboard" class="block text-center text-sm py-2 px-3 rounded-lg transition hover:bg-white/10 mb-2">← Back to Site</a>
      <form method="POST" action="/api/auth/signout">
        <button type="submit" class="w-full block text-center text-sm py-2 px-3 rounded-lg bg-red-600/80 hover:bg-red-600 transition text-white">Sign out</button>
      </form>
    </div>
  </aside>

  <!-- MAIN -->
  <main class="ml-64 min-h-screen">
    <header class="sticky top-0 z-40 flex items-center justify-between px-8 py-4 shadow-sm" style="background:white;border-bottom:2px solid var(--lion-light);">
      <h1 id="page-title" class="text-2xl font-bold" style="color:var(--jet-primary);">Dashboard</h1>
      <div class="flex items-center gap-3 text-sm">
        <span class="px-3 py-1 rounded-full font-semibold text-white text-xs" style="background:var(--butterscotch-primary);">ADMIN</span>
      </div>
    </header>

    <div class="p-8">

      <!-- TAB: DASHBOARD -->
      <section id="tab-dashboard" class="tab-section">
        <div class="grid grid-cols-2 lg:grid-cols-4 gap-5 mb-8">
          {[
            { label:'Total Bookings', value:stats.total,      color:'#ed9b40', icon:'📅' },
            { label:'Pending',        value:stats.pending,    color:'#f59e0b', icon:'⏳' },
            { label:'Contract Signing', value:stats.contractSigning, color:'#3b82f6', icon:'CS' },
            { label:'Booked',      value:stats.booked,  color:'#10b981', icon:'BK' },
            { label:'Cancelled',      value:stats.cancelled,  color:'#ef4444', icon:'❌' },
            { label:'Rescheduled',    value:stats.rescheduled,color:'#8b5cf6', icon:'🔄' },
            { label:'Completed',      value:stats.completed, color:'#64748b', icon:'OK' },
            { label:'Total Revenue',  value:`₱${stats.revenue.toLocaleString()}`, color:'#059669', icon:'💰' },
            { label:'Active Venues',  value:venues?.filter(v=>v.is_active).length??0, color:'#0ea5e9', icon:'🏖️' },
            { label:'Avg Pax (Booked)', value:stats.avgPax||'—', color:'#6366f1', icon:'👥' },
          ].map(c => (
            <div class="bg-white rounded-xl p-5 shadow-sm border border-gray-100 flex items-center gap-4">
              <span class="text-3xl">{c.icon}</span>
              <div>
                <p class="text-xs uppercase tracking-wide text-gray-400 font-semibold">{c.label}</p>
                <p class="text-2xl font-bold" style={`color:${c.color}`}>{c.value}</p>
              </div>
            </div>
          ))}
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex justify-between items-center">
            <h2 class="font-bold text-lg" style="color:var(--jet-primary);">Recent Bookings</h2>
            <button data-tab="bookings" class="nav-btn text-sm font-semibold" style="color:var(--butterscotch-primary);">View all →</button>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                <th class="px-4 py-3 text-left">Guest</th>
                <th class="px-4 py-3 text-left">Venue</th>
                <th class="px-4 py-3 text-left">Event Date</th>
                <th class="px-4 py-3 text-left">Pax</th>
                <th class="px-4 py-3 text-left">Total</th>
                <th class="px-4 py-3 text-left">Status</th>
              </tr></thead>
              <tbody>
                {enrichedBookings.slice(0,8).map(b => (
                  <tr class="border-t border-gray-50 hover:bg-gray-50">
                    <td class="px-4 py-3 font-medium">{b.full_name ?? (b.userName as any)?.email ?? '—'}</td>
                    <td class="px-4 py-3 text-gray-600">{b.venueName ?? '—'}</td>
                    <td class="px-4 py-3 text-gray-600">{b.event_date ? new Date(b.event_date).toLocaleDateString('en-PH') : '—'}</td>
                    <td class="px-4 py-3 text-gray-600">{b.pax ?? '—'}</td>
                    <td class="px-4 py-3 font-semibold" style="color:var(--butterscotch-primary);">{b.total_price ? `₱${Number(b.total_price).toLocaleString()}` : '—'}</td>
                    <td class="px-4 py-3">
                      <span class={`px-2 py-0.5 rounded-full text-xs font-bold ${ b.status==='booked'?'bg-green-100 text-green-700': b.status==='contract_signing'?'bg-blue-100 text-blue-700': b.status==='completed'?'bg-slate-100 text-slate-700': b.status==='cancelled'?'bg-red-100 text-red-700': b.status==='rescheduled'?'bg-purple-100 text-purple-700':'bg-yellow-100 text-yellow-700'}`}>{statusLabels[b.status] ?? b.status}</span>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- TAB: BOOKINGS -->
      <section id="tab-bookings" class="tab-section hidden">

        <!-- Filters + Search bar -->
        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 px-5 py-4 mb-5 flex flex-wrap gap-3 items-center justify-between">
          <div class="flex gap-2 flex-wrap items-center">
            <span class="text-xs font-bold text-gray-400 uppercase tracking-wider mr-1">Filter:</span>
            {[
              { v:'all',         label:'All',          color:'#ed9b40' },
              { v:'pending',     label:'⏳ Pending',    color:'#f59e0b' },
              { v:'contract_signing', label:'Contract Signing', color:'#3b82f6' },
              { v:'booked',   label:'✅ Booked',  color:'#10b981' },
              { v:'cancelled',   label:'❌ Cancelled',  color:'#ef4444' },
              { v:'rescheduled', label:'🔄 Rescheduled',color:'#8b5cf6' },
              { v:'completed', label:'Completed', color:'#64748b' },
            ].map(s => (
              <button data-filter={s.v}
                class="filter-btn px-4 py-1.5 rounded-full text-xs font-bold border-2 transition-all"
                style="border-color:#e5e7eb;color:#6b7280;">
                {s.label}
              </button>
            ))}
          </div>
          <div class="relative">
            <svg class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-300" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
            <input id="bookingSearch" type="text" placeholder="Search guest, venue, phone…"
              class="pl-9 pr-4 py-2 rounded-xl border border-gray-200 text-sm focus:outline-none focus:ring-2 w-64"
              style="focus-ring-color:var(--butterscotch-primary);" />
          </div>
        </div>


        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr style="background:#f8f9fa;border-bottom:2px solid #f3f4f6;">
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Guest</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Venue</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Package</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Event Date</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Hold Period</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Pax</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Total</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Status</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Booked On</th>
                  <th class="px-4 py-3 text-left text-xs font-bold text-gray-400 uppercase tracking-wider">Actions</th>
                </tr>
              </thead>
              <tbody id="bookingsTableBody">
                {(() => {
                  return enrichedBookings.map((b) => {
                    const statusColors = {
                      booked:'bg-green-100 text-green-700',
                      contract_signing:'bg-blue-100 text-blue-700',
                      completed:'bg-slate-100 text-slate-700',
                      cancelled:'bg-red-100 text-red-700',
                      rescheduled:'bg-purple-100 text-purple-700',
                      pending:'bg-yellow-100 text-yellow-700',
                    };
                    return (
                      <tr
                        data-status={b.status}
                        data-search={`${b.full_name??''} ${b.venueName??''} ${b.phone??''} ${b.event_type??''}`}
                        class="booking-row border-t border-gray-50 hover:bg-amber-50 transition-colors"
                        style={b.status==='cancelled'?'opacity:0.6':''}
                      >
                        {/* Guest */}
                        <td class="px-4 py-3">
                          <p class="font-bold" style="color:var(--jet-primary);">{b.full_name??'—'}</p>
                          <p class="text-xs text-gray-400 mt-0.5">{b.phone??(b.userName as any)?.email??''}</p>
                        </td>

                        {/* Venue */}
                        <td class="px-4 py-3">
                          <span class="font-medium text-gray-700">{b.venueName??'—'}</span>
                        </td>

                        {/* Package */}
                        <td class="px-4 py-3 text-gray-500">{b.packageName??b.event_type??'—'}</td>

                        {/* Event date */}
                        <td class="px-4 py-3 font-medium text-gray-700">
                          {b.event_date ? new Date(b.event_date).toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'}) : '—'}
                        </td>

                        {/* Hold period */}
                        <td class="px-4 py-3">
                          <div class="text-xs text-gray-500 whitespace-nowrap">
                            {new Date(b.start_date).toLocaleDateString('en-PH',{month:'short',day:'numeric'})}
                            <span class="text-gray-300 mx-1">→</span>
                            {new Date(b.end_date).toLocaleDateString('en-PH',{month:'short',day:'numeric'})}
                          </div>
                        </td>

                        {/* Pax */}
                        <td class="px-4 py-3 text-gray-600 text-center">{b.pax??'—'}</td>

                        {/* Total */}
                        <td class="px-4 py-3 font-bold" style="color:var(--butterscotch-primary);">
                          {b.total_price?`₱${Number(b.total_price).toLocaleString()}`:'—'}
                        </td>

                        {/* Status */}
                        <td class="px-4 py-3">
                          <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-bold ${statusColors[b.status]??'bg-gray-100 text-gray-600'}`}>
                            {statusLabels[b.status] ?? b.status}
                          </span>
                        </td>

                        {/* Booked on */}
                        <td class="px-4 py-3 text-xs text-gray-400 whitespace-nowrap">
                          {new Date(b.created_at).toLocaleDateString('en-PH',{month:'short',day:'numeric',year:'numeric'})}
                          <div class="text-gray-300">{new Date(b.created_at).toLocaleTimeString('en-PH',{hour:'2-digit',minute:'2-digit'})}</div>
                        </td>

                        {/* Actions */}
                        <td class="px-4 py-3">
                          <div class="flex gap-1.5 flex-wrap">
                            {b.status==='pending'&&(
                              <button onclick={`confirmBooking('${b.id}')`}
                                class="px-2.5 py-1.5 rounded-lg text-xs font-bold text-white transition hover:opacity-80 hover:-translate-y-0.5"
                                style="background:#10b981;">✓ Confirm</button>
                            )}
                            {(b.status==='pending'||b.status==='booked')&&(
                              <button onclick={`openReschedule('${b.id}')`}
                                class="px-2.5 py-1.5 rounded-lg text-xs font-bold text-white transition hover:opacity-80"
                                style="background:#8b5cf6;">↻</button>
                            )}
                            {b.status!=='cancelled'&&b.status!=='rescheduled'&&(
                              <button onclick={`cancelBooking('${b.id}')`}
                                class="px-2.5 py-1.5 rounded-lg text-xs font-bold text-white transition hover:opacity-80"
                                style="background:#ef4444;">✕</button>
                            )}
                            <button onclick={`openBookingDetail(${JSON.stringify(JSON.stringify(b))})`}
                              class="px-2.5 py-1.5 rounded-lg text-xs font-bold border-2 transition hover:bg-gray-50"
                              style="border-color:#cbd5e1;color:#64748b;">👁</button>
                          </div>
                        </td>
                      </tr>
                    );
                  });
                })()}
              </tbody>
            </table>
          </div>
        </div>
      </section>


      <!-- TAB: VENUES -->
      <section id="tab-venues" class="tab-section hidden">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-xl font-bold" style="color:var(--jet-primary);">Manage Venues</h2>
          <button onclick="openVenueModal()" class="px-5 py-2 rounded-lg text-white font-semibold transition hover:opacity-90" style="background:var(--butterscotch-primary);">+ Add Venue</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {venues?.map(v => (
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
              {v.image_url?(<img src={v.image_url} alt={v.name} class="w-full h-40 object-cover" />):(<div class="w-full h-40 flex items-center justify-center text-4xl" style="background:var(--neutral-light);">🏖️</div>)}
              <div class="p-5">
                <div class="flex justify-between items-start mb-2">
                  <h3 class="font-bold text-lg" style="color:var(--jet-primary);">{v.name}</h3>
                  <span class={`text-xs px-2 py-0.5 rounded-full font-bold ${v.is_active?'bg-green-100 text-green-700':'bg-gray-100 text-gray-500'}`}>{v.is_active?'Active':'Inactive'}</span>
                </div>
                <p class="text-sm text-gray-500 mb-1">{v.location??'—'}</p>
                <p class="text-sm text-gray-400 mb-3 line-clamp-2">{v.description??''}</p>
                <div class="flex justify-between text-sm mb-4">
                  <span class="text-gray-500">Cap: <strong>{v.capacity??'—'}</strong></span>
                  <span class="font-bold" style="color:var(--butterscotch-primary);">₱{Number(v.price_per_night).toLocaleString()}/night</span>
                </div>
                <div class="flex gap-2">
                  <button onclick={`openVenueModal(${JSON.stringify(JSON.stringify(v))})`} class="flex-1 py-1.5 rounded-lg text-sm font-semibold border-2 transition hover:bg-gray-50" style="border-color:var(--butterscotch-primary);color:var(--butterscotch-primary);">Edit</button>
                  <button onclick={`toggleVenue('${v.id}',${v.is_active})`} class={`flex-1 py-1.5 rounded-lg text-sm font-semibold text-white transition hover:opacity-80 ${v.is_active?'bg-red-400':'bg-green-500'}`}>{v.is_active?'Deactivate':'Activate'}</button>
                </div>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- TAB: PACKAGES -->
      <section id="tab-packages" class="tab-section hidden">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-xl font-bold" style="color:var(--jet-primary);">Manage Packages</h2>
          <button onclick="openPackageModal()" class="px-5 py-2 rounded-lg text-white font-semibold transition hover:opacity-90" style="background:var(--butterscotch-primary);">+ Add Package</button>
        </div>
        <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
          {packages?.map(p => (
            <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
              <div class="flex justify-between items-start mb-3">
                <h3 class="font-bold text-xl" style="color:var(--jet-primary);">{p.name}</h3>
                <span class={`text-xs px-2 py-0.5 rounded-full font-bold ${p.is_active?'bg-green-100 text-green-700':'bg-gray-100 text-gray-500'}`}>{p.is_active?'Active':'Inactive'}</span>
              </div>
              <p class="text-3xl font-black mb-3" style="color:var(--butterscotch-primary);">₱{Number(p.price).toLocaleString()}</p>
              {p.description&&<p class="text-sm text-gray-500 mb-3">{p.description}</p>}
              {p.inclusions&&<div class="mb-3"><p class="text-xs font-semibold uppercase tracking-wide text-gray-400 mb-1">Inclusions</p><p class="text-sm text-gray-600">{p.inclusions}</p></div>}
              {p.max_pax&&<p class="text-sm text-gray-500 mb-4">Max pax: <strong>{p.max_pax}</strong></p>}
              <div class="flex gap-2">
                <button onclick={`openPackageModal(${JSON.stringify(JSON.stringify(p))})`} class="flex-1 py-1.5 rounded-lg text-sm font-semibold border-2 transition hover:bg-gray-50" style="border-color:var(--butterscotch-primary);color:var(--butterscotch-primary);">Edit</button>
                <button onclick={`togglePackage('${p.id}',${p.is_active})`} class={`flex-1 py-1.5 rounded-lg text-sm font-semibold text-white transition hover:opacity-80 ${p.is_active?'bg-red-400':'bg-green-500'}`}>{p.is_active?'Deactivate':'Activate'}</button>
              </div>
            </div>
          ))}
        </div>
      </section>

      <!-- TAB: REVIEWS -->
      <section id="tab-reviews" class="tab-section hidden">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100"><h2 class="font-bold text-lg" style="color:var(--jet-primary);">All Reviews</h2></div>
          <div class="divide-y divide-gray-50">
            {reviews?.map(r => (
              <div class="px-6 py-5">
                <div class="flex justify-between items-start mb-2">
                  <div>
                    <p class="font-semibold">{(r.reviewUser as any)?.first_name} {(r.reviewUser as any)?.last_name}</p>
                    <p class="text-xs text-gray-400">{(r.reviewUser as any)?.email}</p>
                  </div>
                  <div class="text-right">
                    <div class="flex gap-0.5 mb-1">{Array.from({length:5}).map((_,i)=>(<span class={i<r.rating?'text-yellow-400':'text-gray-200'}>★</span>))}</div>
                    <p class="text-xs text-gray-400">{new Date(r.created_at).toLocaleDateString('en-PH')}</p>
                  </div>
                </div>
                <p class="text-sm text-gray-500">Venue: <strong>{r.reviewVenueName}</strong></p>
                {r.comment&&<p class="text-sm text-gray-700 mt-2 bg-gray-50 rounded-lg px-4 py-3 italic">"{r.comment}"</p>}
              </div>
            ))}
            {(!reviews||reviews.length===0)&&<p class="px-6 py-12 text-center text-gray-400">No reviews yet.</p>}
          </div>
        </div>
      </section>

      <!-- TAB: USERS -->
      <section id="tab-users" class="tab-section hidden">
        <!-- Admins -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden mb-6">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
            <h2 class="font-bold text-lg" style="color:var(--jet-primary);">Admins</h2>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-purple-100 text-purple-700">{allAdmins?.length ?? 0}</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                <th class="px-5 py-3 text-left">Name</th>
                <th class="px-5 py-3 text-left">Email</th>
                <th class="px-5 py-3 text-left">Joined</th>
                <th class="px-5 py-3 text-left">Actions</th>
              </tr></thead>
              <tbody>
                {allAdmins?.map(a => (
                  <tr class="border-t border-gray-50 hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium">{a.first_name??''} {a.last_name??''}</td>
                    <td class="px-5 py-3 text-gray-600">{a.email??'—'}</td>
                    <td class="px-5 py-3 text-gray-400 text-xs">{new Date(a.created_at).toLocaleDateString('en-PH')}</td>
                    <td class="px-5 py-3">
                      <button onclick={`demoteUser('${a.id}')`}
                        class="px-3 py-1 rounded text-xs font-bold border-2 transition hover:bg-gray-50"
                        style="border-color:#ef4444;color:#ef4444;">
                        Demote to Customer
                      </button>
                    </td>
                  </tr>
                ))}
                {(!allAdmins||allAdmins.length===0)&&<tr><td colspan="4" class="px-5 py-8 text-center text-gray-400">No admins found.</td></tr>}
              </tbody>
            </table>
          </div>
        </div>

        <!-- Customers -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
          <div class="px-6 py-4 border-b border-gray-100 flex items-center gap-3">
            <h2 class="font-bold text-lg" style="color:var(--jet-primary);">Customers</h2>
            <span class="px-2 py-0.5 rounded-full text-xs font-bold bg-blue-100 text-blue-700">{allCustomers?.length ?? 0}</span>
          </div>
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                <th class="px-5 py-3 text-left">Name</th>
                <th class="px-5 py-3 text-left">Email</th>
                <th class="px-5 py-3 text-left">Joined</th>
                <th class="px-5 py-3 text-left">Actions</th>
              </tr></thead>
              <tbody>
                {allCustomers?.map(c => (
                  <tr class="border-t border-gray-50 hover:bg-gray-50">
                    <td class="px-5 py-3 font-medium">{c.first_name??''} {c.last_name??''}</td>
                    <td class="px-5 py-3 text-gray-600">{c.email??'—'}</td>
                    <td class="px-5 py-3 text-gray-400 text-xs">{new Date(c.created_at).toLocaleDateString('en-PH')}</td>
                    <td class="px-5 py-3">
                      <button onclick={`promoteUser('${c.id}')`}
                        class="px-3 py-1 rounded text-xs font-bold border-2 transition hover:bg-gray-50"
                        style="border-color:var(--butterscotch-primary);color:var(--butterscotch-primary);">
                        Promote to Admin
                      </button>
                    </td>
                  </tr>
                ))}
                {(!allCustomers||allCustomers.length===0)&&<tr><td colspan="4" class="px-5 py-8 text-center text-gray-400">No customers yet.</td></tr>}
              </tbody>
            </table>
          </div>
        </div>
      </section>

      <!-- TAB: REPORTS -->
      <section id="tab-reports" class="tab-section hidden">

        <!-- Period selector -->
        <div class="flex flex-wrap gap-3 items-center mb-6">
          <div class="flex rounded-xl overflow-hidden border-2 border-gray-200">
            <button id="rpt-btn-weekly"  onclick="switchReport('weekly')"  class="rpt-mode-btn px-5 py-2 text-sm font-semibold transition-all">Weekly</button>
            <button id="rpt-btn-monthly" onclick="switchReport('monthly')" class="rpt-mode-btn px-5 py-2 text-sm font-semibold transition-all">Monthly</button>
          </div>

          <!-- Week picker -->
          <div id="rpt-week-picker" class="flex items-center gap-2">
            <label class="text-sm font-semibold text-gray-500">Week of:</label>
            <input type="date" id="rpt-week-input" class="px-3 py-1.5 rounded-lg border border-gray-200 text-sm focus:outline-none" />
          </div>

          <!-- Month picker -->
          <div id="rpt-month-picker" class="hidden flex items-center gap-2">
            <label class="text-sm font-semibold text-gray-500">Month:</label>
            <input type="month" id="rpt-month-input" class="px-3 py-1.5 rounded-lg border border-gray-200 text-sm focus:outline-none" />
          </div>

          <button onclick="generateReport()" class="px-5 py-2 rounded-xl text-white text-sm font-bold transition hover:opacity-90" style="background:var(--butterscotch-primary);">Generate Report</button>
          <button onclick="printReport()" class="px-5 py-2 rounded-xl text-sm font-bold border-2 transition hover:bg-gray-50" style="border-color:var(--butterscotch-primary);color:var(--butterscotch-primary);">🖨 Print / Save PDF</button>
        </div>

        <!-- Report output (printable area) -->
        <div id="report-output" class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 hidden">

          <!-- Report header -->
          <div class="flex justify-between items-start mb-6 pb-5 border-b border-gray-100">
            <div>
              <h2 id="rpt-title" class="text-2xl font-black" style="color:var(--jet-primary);"></h2>
              <p id="rpt-period" class="text-sm text-gray-400 mt-0.5"></p>
            </div>
            <p class="text-xs text-gray-400">Generated: <span id="rpt-generated"></span></p>
          </div>

          <!-- Metric cards -->
          <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-4 mb-8">
            {[
              { id:'rpt-total',       label:'Total Requests', color:'#ed9b40', icon:'📅' },
              { id:'rpt-confirmed',   label:'Booked',      color:'#10b981', icon:'✅' },
              { id:'rpt-cancelled',   label:'Cancelled',      color:'#ef4444', icon:'❌' },
              { id:'rpt-rescheduled', label:'Rescheduled',    color:'#8b5cf6', icon:'🔄' },
              { id:'rpt-revenue',     label:'Revenue',        color:'#059669', icon:'💰' },
            ].map(c => (
              <div class="rounded-xl p-4 border border-gray-100 bg-gray-50 flex flex-col items-center text-center">
                <span class="text-2xl mb-1">{c.icon}</span>
                <p class="text-xs uppercase tracking-wide text-gray-400 font-semibold mb-1">{c.label}</p>
                <p id={c.id} class="text-2xl font-black" style={`color:${c.color}`}>—</p>
              </div>
            ))}
          </div>

          <!-- Distribution by date -->
          <div class="mb-8">
            <h3 class="text-sm font-bold uppercase tracking-wide text-gray-400 mb-3">Booking Distribution by Date</h3>
            <div id="rpt-distribution" class="space-y-2 text-sm"></div>
          </div>

          <!-- Breakdown by event type/package -->
          <div class="mb-8">
            <h3 class="text-sm font-bold uppercase tracking-wide text-gray-400 mb-3">Breakdown by Event Type / Package</h3>
            <div id="rpt-breakdown" class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                  <th class="px-4 py-2 text-left">Event / Package</th>
                  <th class="px-4 py-2 text-left">Bookings</th>
                  <th class="px-4 py-2 text-left">Revenue</th>
                </tr></thead>
                <tbody id="rpt-breakdown-body"></tbody>
              </table>
            </div>
          </div>

          <!-- Bookings table -->
          <div>
            <h3 class="text-sm font-bold uppercase tracking-wide text-gray-400 mb-3">All Bookings in Period</h3>
            <div class="overflow-x-auto">
              <table class="w-full text-sm">
                <thead><tr class="bg-gray-50 text-gray-500 text-xs uppercase tracking-wide">
                  <th class="px-3 py-2 text-left">Guest</th>
                  <th class="px-3 py-2 text-left">Venue</th>
                  <th class="px-3 py-2 text-left">Package</th>
                  <th class="px-3 py-2 text-left">Event Date</th>
                  <th class="px-3 py-2 text-left">Pax</th>
                  <th class="px-3 py-2 text-left">Total</th>
                  <th class="px-3 py-2 text-left">Status</th>
                </tr></thead>
                <tbody id="rpt-bookings-body"></tbody>
              </table>
            </div>
          </div>

        </div><!-- /report-output -->

        <div id="report-empty" class="text-center py-16 text-gray-400">
          <p class="text-4xl mb-3">📈</p>
          <p class="font-semibold">Select a period and click <strong>Generate Report</strong></p>
        </div>

      </section>

      <!-- TAB: AVAILABILITY CALENDAR -->
      <section id="tab-calendar" class="tab-section hidden">
        <div class="flex flex-wrap gap-4 items-start justify-between mb-6">
          <div>
            <h2 class="text-xl font-bold" style="color:var(--jet-primary);">Availability Calendar</h2>
            <p class="text-sm text-gray-500 mt-0.5">Click any date to view bookings. Confirm, cancel, or reschedule from here.</p>
          </div>
          <div class="flex gap-2 flex-wrap items-center">
            <button id="adm-prev-month" class="w-9 h-9 rounded-lg border-2 border-gray-200 flex items-center justify-center hover:bg-gray-50 transition text-gray-600">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
            </button>
            <span id="adm-month-label" class="font-bold text-lg px-3" style="color:var(--jet-primary);min-width:160px;text-align:center;"></span>
            <button id="adm-next-month" class="w-9 h-9 rounded-lg border-2 border-gray-200 flex items-center justify-center hover:bg-gray-50 transition text-gray-600">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>

        <div class="flex gap-4 flex-wrap mb-5">
          {[
            { bg:'#dcfce7', ring:'#22c55e', label:'Available' },
            { bg:'#fef2f2', ring:'#ef4444', label:'Booked' },
            { bg:'#fffbeb', ring:'#f59e0b', label:'Pending' },
            { bg:'#f3e8ff', ring:'#a855f7', label:'Rescheduled' },
          ].map(l => (
            <div class="flex items-center gap-2">
              <div class="w-5 h-5 rounded-md" style={`background:${l.bg};outline:1.5px solid ${l.ring};`}></div>
              <span class="text-sm font-medium text-gray-600">{l.label}</span>
            </div>
          ))}
        </div>

        <div class="bg-white rounded-2xl shadow-sm border border-gray-100 overflow-hidden">
          <div style="display:grid;grid-template-columns:repeat(7,1fr);background:#f9fafb;border-bottom:1px solid #f3f4f6;">
            {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(d => (
              <div style="text-align:center;font-size:0.78rem;font-weight:700;color:#6b7280;padding:10px 0;">{d}</div>
            ))}
          </div>
          <div id="adm-cal-grid" style="display:grid;grid-template-columns:repeat(7,1fr);"></div>
          <div id="adm-cal-loading" style="display:none;text-align:center;padding:20px;color:#888;font-size:0.875rem;">Loading bookings…</div>
        </div>

        <div id="adm-day-detail" class="hidden mt-6 bg-white rounded-2xl shadow-sm border border-gray-100 p-6">
          <div class="flex justify-between items-center mb-4">
            <h3 id="adm-detail-date" class="text-lg font-bold" style="color:var(--jet-primary);"></h3>
            <button id="adm-detail-close" class="text-gray-400 hover:text-gray-600 text-xl leading-none">&times;</button>
          </div>
          <div id="adm-detail-content" class="space-y-3 text-sm"></div>
        </div>
      </section>

    </div>
  </main>
</div>

<!-- BOOKING DETAILS MODAL (Fig 19) -->
