      <section class="confirmation-next-steps">
        <p class="confirmation-section__eyebrow">What happens next</p>
        <ol>
          <li>Submit this booking request for staff review.</li>
          <li>Woodberry staff will confirm details with you.</li>
          <li>Contract signing and minimum payment happen face-to-face.</li>
        </ol>
      </section>
    </div>

    <div class="booking-confirmation__footer">
      <button id="conf-back-btn" class="confirmation-button confirmation-button--secondary">
        Go Back & Edit
      </button>
      <button id="conf-submit-btn" class="confirmation-button confirmation-button--primary">
        Submit Booking Request
      </button>
    </div>
  </div>
</div>

<!-- Booking success screen -->
<div
  id="bookingSuccessScreen"
  class="hidden fixed inset-0 z-50 flex items-center justify-center"
  style="background:rgba(0,0,0,0.6);"
>
  <div class="booking-success-card">
    <div class="booking-success-card__mark" aria-hidden="true">
      <svg viewBox="0 0 48 48" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="24" cy="24" r="20" fill="currentColor" opacity="0.16"/>
        <path d="m15 24 6 6 13-14" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </div>
    <p class="booking-success-card__eyebrow">Booking request received</p>
    <h3>We have your Woodberry request</h3>
    <p class="booking-success-card__intro">
      Thank you. Our staff will review your details and coordinate the next
      steps for face-to-face contract signing.
    </p>

    <div class="booking-success-card__reference">
      <span>Booking Reference</span>
      <p id="success-ref"></p>
      <small id="success-venue"></small>
      <small id="success-dates"></small>
    </div>

    <div class="booking-success-card__steps">
      <div>
        <span>1</span>
        <p>Staff reviews your booking request.</p>
      </div>
      <div>
        <span>2</span>
        <p>Contract signing and 50% minimum payment happen face-to-face.</p>
      </div>
      <div>
        <span>3</span>
        <p>You can track the booking status in your dashboard.</p>
