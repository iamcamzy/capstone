    <p class="booking-success-card__redirect">
      Redirecting to your dashboard in <span id="success-countdown">5</span>s.
    </p>
    <a href="/dashboard" class="confirmation-button confirmation-button--primary">
      Go to Dashboard Now
    </a>
  </div>
</div>

<script is:inline define:vars={{ venueId, venueName, pricePerNight }}>
  var form = document.getElementById("bookingForm");
  var checkInInput = document.getElementById("checkIn");
  var checkOutInput = document.getElementById("checkOut");
  var eventDateInput = document.getElementById("eventDate");
  var termsAcceptedInput = document.getElementById("termsAccepted");
  var addressInput = document.getElementById("address");
  var catererInput = document.getElementById("caterer");
  var useWoodberryCatererInput = document.getElementById("useWoodberryCaterer");
  var roomsCountInput = document.getElementById("roomsCount");
  var nightsCountEl = document.getElementById("nightsCount");
  var totalPriceEl = document.getElementById("totalPrice");
  var minimumPaymentEl = document.getElementById("minimumPayment");
  var remainingBalanceEl = document.getElementById("remainingBalance");
  var noticeEl = document.getElementById("bookingNotice");
  var termsModal = document.getElementById("termsModal");
  var confirmModal = document.getElementById("bookingConfirmModal");
  var successScreen = document.getElementById("bookingSuccessScreen");
  var termsBackBtn = document.getElementById("terms-back-btn");
  var termsContinueBtn = document.getElementById("terms-continue-btn");
  var confBackBtn = document.getElementById("conf-back-btn");
  var confSubmitBtn = document.getElementById("conf-submit-btn");
  var pricePerNightValue = Number(pricePerNight) || 0;
  var woodberryCatererName = "Woodberry's Caterer";
  var facilityOptions = [
    { key: "pavillion", label: "Pavillion" },
    { key: "pool", label: "Pool" },
    { key: "rooms", label: "Rooms" },
    { key: "sound-system", label: "Sound System" },
    { key: "videoke", label: "Videoke" },
  ];

  var ppnDisplay = document.getElementById("pricePerNightDisplay");
  if (ppnDisplay) ppnDisplay.textContent = formatCurrency(pricePerNightValue);

  function formatCurrency(amount) {
    return new Intl.NumberFormat("en-PH", {
      style: "currency",
      currency: "PHP",
      minimumFractionDigits: 2,
    }).format(Number(amount) || 0);
  }

  function fmtDate(str) {
    if (!str) return "N/A";
    var d = new Date(str + "T00:00:00");
    return d.toLocaleDateString("en-PH", {
      year: "numeric",
      month: "long",
      day: "numeric",
    });
  }

  function fmtDateTime(str) {
    if (!str) return "Not specified";
    return new Date(str).toLocaleString("en-PH", {
      year: "numeric",
      month: "short",
      day: "numeric",
      hour: "numeric",
      minute: "2-digit",
    });
  }

  function parseDateOnly(str) {
    if (!str) return null;
    var parts = str.split("-").map(Number);
    return new Date(parts[0], parts[1] - 1, parts[2]);
  }

  function parseDateTimeLocal(str) {
    if (!str) return null;
    var date = new Date(str);
    return Number.isNaN(date.getTime()) ? null : date;
  }

  function formatDateOnly(date) {
    var year = date.getFullYear();
    var month = String(date.getMonth() + 1).padStart(2, "0");
    var day = String(date.getDate()).padStart(2, "0");
    return year + "-" + month + "-" + day;
  }

  function addOneCalendarMonth(date) {
    var oneMonthLater = new Date(
      date.getFullYear(),
      date.getMonth() + 1,
      date.getDate(),
    );
    if (oneMonthLater.getDate() !== date.getDate()) {
      oneMonthLater.setDate(0);
    }
    return oneMonthLater;
  }

  function getMinimumBookingDate() {
    var today = new Date();
    today.setHours(0, 0, 0, 0);
    return addOneCalendarMonth(today);
  }

  var minimumBookingDate = getMinimumBookingDate();
  var minimumBookingDateValue = formatDateOnly(minimumBookingDate);
  checkInInput.min = minimumBookingDateValue;
  checkOutInput.min = minimumBookingDateValue;
  eventDateInput.min = minimumBookingDateValue;

  function showNotice(msg, type) {
    if (!noticeEl) return;
    noticeEl.className =
      "mb-4 px-4 py-3 rounded-lg text-sm font-semibold flex items-center gap-2 " +
      (type === "success"
        ? "bg-green-100 text-green-800"
        : "bg-red-100 text-red-800");
    noticeEl.textContent = (type === "success" ? "Success: " : "Error: ") + msg;
    noticeEl.classList.remove("hidden");
    noticeEl.scrollIntoView({ behavior: "smooth", block: "nearest" });
  }

  function calculateNights() {
    var nights = 0;
    if (checkInInput.value && checkOutInput.value) {
      var checkIn = parseDateOnly(checkInInput.value);
      var checkOut = parseDateOnly(checkOutInput.value);
      if (checkIn && checkOut && checkOut > checkIn) {
        nights = Math.ceil((checkOut - checkIn) / 86400000);
      }
    }

    var total = nights * pricePerNightValue;
    var minimumPayment = total * 0.5;
    var remainingBalance = total - minimumPayment;

    nightsCountEl.textContent = String(nights);
    totalPriceEl.textContent = formatCurrency(total);
    minimumPaymentEl.textContent = formatCurrency(minimumPayment);
    remainingBalanceEl.textContent = formatCurrency(remainingBalance);

    return {
      nights: nights,
      total: total,
      minimumPayment: minimumPayment,
      remainingBalance: remainingBalance,
    };
  }

  function getFacilityCheckbox(key) {
    return document.querySelector('[data-facility="' + key + '"]');
  }

  function getFacilityFromInput(key) {
    return document.querySelector('[data-facility-from="' + key + '"]');
  }

  function getFacilityToInput(key) {
    return document.querySelector('[data-facility-to="' + key + '"]');
  }

  function syncFacility(key) {
    var checkbox = getFacilityCheckbox(key);
    var timeRange = document.querySelector('[data-time-range="' + key + '"]');
    var fromInput = getFacilityFromInput(key);
    var toInput = getFacilityToInput(key);
    var isChecked = checkbox && checkbox.checked;

    if (timeRange) timeRange.classList.toggle("hidden", !isChecked);
    if (!isChecked) {
      if (fromInput) fromInput.value = "";
      if (toInput) toInput.value = "";
    }

    if (key === "rooms" && roomsCountInput) {
      roomsCountInput.disabled = !isChecked;
      if (!isChecked) roomsCountInput.value = "";
    }
  }

  function syncAllFacilities() {
    facilityOptions.forEach(function (facility) {
      syncFacility(facility.key);
    });
  }

  function syncCaterer() {
    if (!catererInput || !useWoodberryCatererInput) return;
    if (useWoodberryCatererInput.checked) {
      catererInput.value = woodberryCatererName;
      catererInput.disabled = true;
    } else {
      catererInput.disabled = false;
      if (catererInput.value === woodberryCatererName) catererInput.value = "";
    }
  }

  function getSelectedInclusions() {
    return facilityOptions
      .map(function (facility) {
        var checkbox = getFacilityCheckbox(facility.key);
        if (!checkbox || !checkbox.checked) return null;
        return {
          key: facility.key,
          label: facility.label,
          from: getFacilityFromInput(facility.key)?.value || "",
          to: getFacilityToInput(facility.key)?.value || "",
          roomsCount:
            facility.key === "rooms" && roomsCountInput ? roomsCountInput.value : "",
        };
      })
      .filter(Boolean);
  }

  function isDateTimeWithinBookingDates(date) {
    var selectedStartDate = parseDateOnly(checkInInput.value);
    var selectedEndDate = parseDateOnly(checkOutInput.value);
    var selectedEventDate = parseDateOnly(eventDateInput.value);
    if (!date || !selectedStartDate || !selectedEndDate) return false;

    var bookingStart = new Date(selectedStartDate);
    bookingStart.setHours(0, 0, 0, 0);
    var bookingEnd = new Date(selectedEndDate);
    bookingEnd.setHours(23, 59, 59, 999);

    var withinBooking = date >= bookingStart && date <= bookingEnd;
    var withinEventDate = false;
    if (selectedEventDate) {
      var eventStart = new Date(selectedEventDate);
      eventStart.setHours(0, 0, 0, 0);
      var eventEnd = new Date(selectedEventDate);
      eventEnd.setHours(23, 59, 59, 999);
      withinEventDate = date >= eventStart && date <= eventEnd;
    }

    return withinBooking || withinEventDate;
  }

  function validateFacilityRanges(inclusions) {
    for (var i = 0; i < inclusions.length; i++) {
      var inclusion = inclusions[i];
      var fromDate = parseDateTimeLocal(inclusion.from);
      var toDate = parseDateTimeLocal(inclusion.to);

      if (fromDate && toDate && toDate <= fromDate) {
        showNotice("Facility time range To must be after From.", "error");
        return false;
      }

      if (
        (fromDate && !isDateTimeWithinBookingDates(fromDate)) ||
        (toDate && !isDateTimeWithinBookingDates(toDate))
      ) {
        showNotice(
          "Facility time ranges must fall within the selected booking dates.",
          "error",
        );
        return false;
      }
    }
    return true;
  }

  function getEventTypeLabel() {
    var eventType = document.getElementById("eventType");
    if (!eventType || !eventType.value) return "N/A";
    return eventType.options[eventType.selectedIndex].textContent || eventType.value;
  }

  function populateInclusionSummary(inclusions) {
    var wrap = document.getElementById("conf-inclusions");
    if (!wrap) return;
    wrap.innerHTML = "";

    if (!inclusions.length) {
      var empty = document.createElement("div");
      empty.className = "booking-summary-card booking-summary-card--empty";
      empty.textContent = "No package inclusions selected.";
      wrap.appendChild(empty);
      return;
    }

    inclusions.forEach(function (inclusion) {
      var item = document.createElement("div");
      item.className = "booking-summary-card";

      var title = document.createElement("p");
      title.className = "font-semibold";
      title.textContent =
        inclusion.label +
        (inclusion.key === "rooms" && inclusion.roomsCount
          ? " (" + inclusion.roomsCount + " room" + (inclusion.roomsCount === "1" ? "" : "s") + ")"
          : "");
      item.appendChild(title);

      var from = document.createElement("p");
      from.className = "booking-summary-card__meta";
      from.textContent = "From: " + fmtDateTime(inclusion.from);
      item.appendChild(from);

      var to = document.createElement("p");
      to.className = "booking-summary-card__meta";
      to.textContent = "To: " + fmtDateTime(inclusion.to);
      item.appendChild(to);

      wrap.appendChild(item);
    });
  }

  checkInInput.addEventListener("change", function () {
    checkOutInput.min =
      checkInInput.value && checkInInput.value > minimumBookingDateValue
        ? checkInInput.value
        : minimumBookingDateValue;
    calculateNights();
  });
  checkOutInput.addEventListener("change", calculateNights);
  useWoodberryCatererInput.addEventListener("change", syncCaterer);
  facilityOptions.forEach(function (facility) {
    var checkbox = getFacilityCheckbox(facility.key);
    if (checkbox) {
      checkbox.addEventListener("change", function () {
        syncFacility(facility.key);
      });
    }
  });

  function validateMainForm() {
    if (noticeEl) noticeEl.classList.add("hidden");

    if (!form.checkValidity()) {
      showNotice("Please complete all required booking details.", "error");
      form.reportValidity();
      return false;
    }

    var selectedStartDate = parseDateOnly(checkInInput.value);
    var selectedEndDate = parseDateOnly(checkOutInput.value);
    var selectedEventDate = parseDateOnly(eventDateInput.value);

    if (
      !selectedStartDate ||
      !selectedEndDate ||
      !selectedEventDate ||
      selectedStartDate < minimumBookingDate ||
      selectedEndDate < minimumBookingDate ||
      selectedEventDate < minimumBookingDate
    ) {
      showNotice("Bookings must be made at least one month in advance.", "error");
      return false;
    }

    if (selectedEndDate <= selectedStartDate) {
      showNotice("Check-out date must be after check-in date.", "error");
      return false;
    }

    if (selectedEventDate < selectedStartDate || selectedEventDate > selectedEndDate) {
      showNotice("Event date must fall within the selected booking dates.", "error");
      return false;
    }

    var inclusions = getSelectedInclusions();
    if (!validateFacilityRanges(inclusions)) return false;

    return true;
  }

  function openConfirmationModal() {
    var inclusions = getSelectedInclusions();
    var totals = calculateNights();
    var catererValue = catererInput.value.trim() || "N/A";

    document.getElementById("conf-venue").textContent = venueName || "Venue";
    document.getElementById("conf-name").textContent =
      document.getElementById("fullName").value || "N/A";
    document.getElementById("conf-phone").textContent =
      document.getElementById("phone").value || "N/A";
    document.getElementById("conf-email").textContent =
      document.getElementById("email").value || "N/A";
    document.getElementById("conf-address").textContent = addressInput.value || "N/A";
    document.getElementById("conf-checkin").textContent = fmtDate(checkInInput.value);
    document.getElementById("conf-checkout").textContent = fmtDate(checkOutInput.value);
    document.getElementById("conf-eventdate").textContent = fmtDate(eventDateInput.value);
    document.getElementById("conf-guests").textContent =
      document.getElementById("guests").value + " guests";
    document.getElementById("conf-eventtype").textContent = getEventTypeLabel();
    document.getElementById("conf-nights").textContent =
      totals.nights + " night" + (totals.nights !== 1 ? "s" : "");
    document.getElementById("conf-caterer").textContent = catererValue;
    document.getElementById("conf-total").textContent = formatCurrency(totals.total);
    document.getElementById("conf-minimum-payment").textContent = formatCurrency(
      totals.minimumPayment,
    );
    document.getElementById("conf-remaining-balance").textContent = formatCurrency(
      totals.remainingBalance,
    );
    populateInclusionSummary(inclusions);

    var requests = document.getElementById("specialRequests").value;
    var reqWrap = document.getElementById("conf-requests-wrap");
    if (requests) {
      document.getElementById("conf-requests").textContent = requests;
      reqWrap.classList.remove("hidden");
    } else {
      reqWrap.classList.add("hidden");
    }

    confirmModal.classList.remove("hidden");
  }

  form.addEventListener("submit", function (e) {
    e.preventDefault();
    if (!validateMainForm()) return;
    termsModal.classList.remove("hidden");
  });

  termsBackBtn.addEventListener("click", function () {
    termsModal.classList.add("hidden");
  });

  termsModal.addEventListener("click", function (e) {
    if (e.target === termsModal) termsModal.classList.add("hidden");
  });

  termsContinueBtn.addEventListener("click", function () {
    if (noticeEl) noticeEl.classList.add("hidden");

    if (!termsAcceptedInput.checked) {
      showNotice(
        "You must agree to the Terms and Conditions before submitting your booking.",
        "error",
      );
      termsAcceptedInput.focus();
      return;
    }

    if (!validateMainForm()) return;
    termsModal.classList.add("hidden");
    openConfirmationModal();
  });

  confBackBtn.addEventListener("click", function () {
    confirmModal.classList.add("hidden");
  });

  confirmModal.addEventListener("click", function (e) {
    if (e.target === confirmModal) confirmModal.classList.add("hidden");
  });

  confSubmitBtn.addEventListener("click", async function () {
    if (!termsAcceptedInput.checked) {
      showNotice(
        "You must agree to the Terms and Conditions before submitting your booking.",
        "error",
      );
      confirmModal.classList.add("hidden");
      termsModal.classList.remove("hidden");
      termsAcceptedInput.focus();
      return;
    }

    confSubmitBtn.disabled = true;
    confSubmitBtn.textContent = "Submitting...";

    var inclusions = getSelectedInclusions();
    var totals = calculateNights();
    var catererValue = catererInput.value.trim();

    var formData = {
      venueId: venueId,
      startDate: checkInInput.value,
      endDate: checkOutInput.value,
      eventDate: eventDateInput.value || null,
      fullName: document.getElementById("fullName").value,
      email: document.getElementById("email").value,
      phone: document.getElementById("phone").value,
      pax: parseInt(document.getElementById("guests").value) || null,
      eventType: document.getElementById("eventType").value || null,
      specialRequests: document.getElementById("specialRequests").value || null,
      address: addressInput.value || null,
      caterer: useWoodberryCatererInput.checked ? woodberryCatererName : catererValue || null,
      useWoodberryCaterer: useWoodberryCatererInput.checked,
      packageInclusions: inclusions,
      roomsCount: roomsCountInput.value ? parseInt(roomsCountInput.value) : null,
      facilityTimeRanges: inclusions.map(function (inclusion) {
        return {
          key: inclusion.key,
          from: inclusion.from || null,
          to: inclusion.to || null,
        };
      }),
      additionals: null,
      minimumPaymentAmount: totals.minimumPayment,
      remainingBalanceAmount: totals.remainingBalance,
      termsAccepted: termsAcceptedInput.checked,
    };

    try {
      var response = await fetch("/api/bookings/CreateBookings", {
        method: "POST",
        headers: { "Content-Type": "application/json" },
        body: JSON.stringify(formData),
      });

      var result = await response.json().catch(function () {
        return {};
      });

      if (response.ok) {
        confirmModal.classList.add("hidden");
        var refId = result.bookingId
          ? result.bookingId.substring(0, 8).toUpperCase()
          : "N/A";
        document.getElementById("success-ref").textContent = "REF-" + refId;
        document.getElementById("success-venue").textContent = venueName || "";
        document.getElementById("success-dates").textContent =
          fmtDate(checkInInput.value) + " to " + fmtDate(checkOutInput.value);
        successScreen.classList.remove("hidden");
        form.reset();
        syncCaterer();
        syncAllFacilities();
        calculateNights();
        var seconds = 5;
        var countdown = document.getElementById("success-countdown");
        var timer = setInterval(function () {
          seconds--;
          if (countdown) countdown.textContent = String(seconds);
          if (seconds <= 0) {
            clearInterval(timer);
            window.location.href = "/dashboard";
          }
        }, 1000);
      } else {
        confirmModal.classList.add("hidden");
        showNotice(
          "Booking failed: " + (result.error ?? "Please try again."),
          "error",
        );
      }
    } catch (err) {
      confirmModal.classList.add("hidden");
      showNotice(
        "An error occurred. Please check your connection and try again.",
        "error",
      );
    } finally {
      confSubmitBtn.disabled = false;
      confSubmitBtn.textContent = "Submit Booking Request";
    }
  });

  syncCaterer();
  syncAllFacilities();
  calculateNights();
</script>

<style>
  .booking-shell {
    color: var(--wb-text);
  }

  .booking-form__header {
    margin-bottom: 1.4rem;
  }

  .booking-form__eyebrow {
    margin: 0 0 0.35rem;
    color: var(--wb-green);
    font-size: 0.72rem;
    font-weight: 800;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .booking-form__header h2 {
    margin: 0;
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.9rem, 4vw, 2.65rem);
    letter-spacing: 0;
  }

  .booking-form__header p:last-child {
    max-width: 42rem;
    margin: 0.55rem 0 0;
    color: var(--wb-muted);
    font-size: 0.96rem;
  }

  .booking-flow {
    display: grid;
    gap: 1.1rem;
  }

  #bookingNotice {
    border: 1px solid transparent;
    border-radius: var(--wb-radius-md);
    box-shadow: var(--wb-shadow-sm);
  }

  #bookingNotice.bg-green-100 {
    border-color: #c9ddbf;
    background: var(--wb-green-soft) !important;
    color: var(--wb-green-dark) !important;
  }

  #bookingNotice.bg-red-100 {
    border-color: #e7b8ab;
    background: #fbe7df !important;
    color: #8f2f20 !important;
  }

