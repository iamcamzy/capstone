---
import CalendarPreview from './calendarComps/calendarPreview.astro';
import Theme from './ThemeButton.astro';
import { getUser } from '../lib/auth';
import { supabase, supabaseAdmin } from '../lib/supabase';

const user = await getUser(Astro.cookies);

let isAdmin = false;
if (user) {
  const client = supabaseAdmin ?? supabase;
  const { data } = await client
    .from('admins')
    .select('id')
    .eq('id', user.id)
    .single();
  isAdmin = !!data;
}
---

<header id="navbar" class="site-header">
  <div class="site-header__inner">
    <a href="/" class="site-header__logo" aria-label="Woodberry home">
      <img src="/company-logo-clean.png" alt="Woodberry logo" width="190" height="56" loading="eager" decoding="async" />
    </a>

    <nav id="desktopNav" class="site-header__nav" aria-label="Main navigation">
      <a href="/" class="navigation-link"><span class="navigation-button">HOME</span></a>
      <a href="/events_and_booking/events" class="navigation-link"><span class="navigation-button">EVENTS</span></a>
      <a href="/gallery" class="navigation-link"><span class="navigation-button">GALLERY</span></a>
      <a href="/contact-us" class="navigation-link"><span class="navigation-button">CONTACT US</span></a>
    </nav>

    <div class="site-header__actions">
      <button id="preview" class="availability-btn" type="button" aria-label="Toggle availability calendar" aria-expanded="false">
        <svg id="previewIconCal" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"></rect>
          <line x1="3" y1="10" x2="21" y2="10"></line>
          <line x1="8" y1="2" x2="8" y2="6"></line>
          <line x1="16" y1="2" x2="16" y2="6"></line>
        </svg>
        <svg id="previewIconX" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="14" height="14" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
        <span id="previewText">Availability</span>
      </button>

      {!user && <a href="/signin" class="auth-btn auth-btn--ghost">Log In</a>}
      {!user && <a href="/signup" class="auth-btn auth-btn--dark">Sign Up</a>}
      {user && isAdmin && <a href="/dashboard" class="auth-btn auth-btn--green">Dashboard</a>}
      {user && isAdmin && <a href="/admin" class="auth-btn auth-btn--dark">Admin</a>}
      {user && !isAdmin && <a href="/dashboard" class="auth-btn auth-btn--dark">My Dashboard</a>}

      <Theme />

      <button id="mobileMenuBtn" class="mobile-menu-btn" type="button" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div id="mobileMenuBackdrop" class="mobile-menu-backdrop" hidden></div>
  <aside id="mobileMenu" class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu__top">
      <img src="/company-logo-clean.png" alt="Woodberry logo" width="150" height="44" loading="lazy" decoding="async" />
      <button id="mobileMenuClose" class="mobile-menu__close" type="button" aria-label="Close menu">×</button>
    </div>
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      <a href="/">Home</a>
      <a href="/events_and_booking/events">Events</a>
      <a href="/gallery">Gallery</a>
      <a href="/contact-us">Contact Us</a>
      {user ? <a href="/dashboard">My Dashboard</a> : <a href="/signin">Log In</a>}
      {user && isAdmin && <a href="/admin">Admin Panel</a>}
    </nav>
  </aside>
</header>
<CalendarPreview />

<script>
  const menuBtn = document.getElementById('mobileMenuBtn');
  const menu = document.getElementById('mobileMenu');
  const backdrop = document.getElementById('mobileMenuBackdrop');
  const closeBtn = document.getElementById('mobileMenuClose');

  function setMenu(open: boolean) {
    if (!menu || !backdrop || !menuBtn) return;
    menu.classList.toggle('is-open', open);
    backdrop.hidden = !open;
    menu.setAttribute('aria-hidden', String(!open));
    menuBtn.setAttribute('aria-expanded', String(open));
    document.body.style.overflow = open ? 'hidden' : '';
  }

  menuBtn?.addEventListener('click', () => setMenu(true));
  closeBtn?.addEventListener('click', () => setMenu(false));
  backdrop?.addEventListener('click', () => setMenu(false));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setMenu(false); });
</script>

<style>
  .site-header{position:fixed;top:0;left:0;width:100%;z-index:100;background:#f5f7f1;box-shadow:0 2px 12px rgba(74,124,63,.10)}
  .site-header__inner{height:70px;padding:0 clamp(1rem,3vw,1.5rem);display:flex;align-items:center;gap:1rem}
  .site-header__logo{width:220px;flex-shrink:0;display:flex;align-items:center}.site-header__logo img{max-height:56px;width:auto}
  .site-header__nav{display:flex;align-items:center;justify-content:center;flex:1;gap:clamp(1rem,2.5vw,2rem)}
  .navigation-link{text-decoration:none}.navigation-button{font-weight:700;font-size:.85rem;color:#1a2e10;letter-spacing:.05em}.navigation-link:hover .navigation-button{color:#2d5a27}
  .site-header__actions{display:flex;align-items:center;gap:.5rem;flex-shrink:0}.availability-btn,.auth-btn{height:36px;display:inline-flex;align-items:center;justify-content:center;border-radius:10px;font-weight:700;font-size:.82rem;text-decoration:none;white-space:nowrap;transition:.2s ease}.availability-btn{gap:.4rem;width:120px;border:2px solid #4a7c3f;color:#4a7c3f;background:transparent;cursor:pointer}.auth-btn{padding:0 .9rem}.auth-btn--ghost{border:2px solid #4a7c3f;color:#4a7c3f}.auth-btn--dark{background:#1a1a1a;color:#fff}.auth-btn--green{background:#4a7c3f;color:#fff}
  .mobile-menu-btn{display:none;width:40px;height:40px;border:0;background:#1a2e10;border-radius:10px;padding:9px;cursor:pointer}.mobile-menu-btn span{display:block;height:2px;background:#fff;margin:5px 0;border-radius:999px}.mobile-menu-backdrop{position:fixed;inset:70px 0 0;background:rgba(0,0,0,.38);z-index:101}.mobile-menu{position:fixed;top:70px;right:0;width:min(86vw,340px);height:calc(100vh - 70px);background:#fff;z-index:102;transform:translateX(100%);transition:transform .25s ease;box-shadow:-12px 0 30px rgba(0,0,0,.16);padding:1rem}.mobile-menu.is-open{transform:translateX(0)}.mobile-menu__top{display:flex;align-items:center;justify-content:space-between;border-bottom:1px solid #e5e7eb;padding-bottom:1rem}.mobile-menu__close{border:0;background:#f3f4f6;width:36px;height:36px;border-radius:999px;font-size:1.6rem;line-height:1;cursor:pointer}.mobile-menu__nav{display:grid;gap:.75rem;padding-top:1rem}.mobile-menu__nav a{padding:.9rem 1rem;border-radius:14px;background:#f8faf6;color:#1a2e10;text-decoration:none;font-weight:800}
  @media(max-width:980px){.site-header__nav,.availability-btn,.auth-btn{display:none}.site-header__inner{justify-content:space-between}.site-header__logo{width:auto}.mobile-menu-btn{display:block}}
</style>
