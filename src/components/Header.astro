---
import CalendarPreview from './calendarComps/calendarPreview.astro';
import Theme from './ThemeButton.astro';
import { getUser } from '../lib/auth';
import { supabase, supabaseAdmin } from '../lib/supabase';

const user = await getUser(Astro.cookies);

let isAdmin = false;
if (user) {
  const client = supabaseAdmin ?? supabase;
  const { data } = await client
    .from('admins')
    .select('id')
    .eq('id', user.id)
    .single();
  isAdmin = !!data;
}
---

<header
  id="navbar"
  class="fixed top-0 left-0 w-full transition-transform duration-300 z-100 max-w-screen"
  style="background: #f5f7f1; box-shadow: 0 2px 12px rgba(74,124,63,0.10);"
>
  <!-- Main row -->
  <div class="flex items-center w-full" style="height: 70px; padding: 0 1.5rem;">

    <!-- Logo -->
    <div id="company_logo" class="flex items-center" style="width: 240px; flex-shrink: 0;">
      <a href="/" target="_self" class="hover:opacity-80 transition-opacity">
        <img src="/company-logo-clean.png" alt="company logo" style="max-height: 56px; width: auto;" />
      </a>
    </div>

    <!-- Nav -->
    <nav id="navigation" class="flex items-center justify-center flex-1 gap-8">
      <a href="/" class="navigation-link"><span class="navigation-button">HOME</span></a>
      <a href="/events_and_booking/events" class="navigation-link"><span class="navigation-button">BOOKINGS</span></a>
      <a href="/gallery" class="navigation-link"><span class="navigation-button">GALLERY</span></a>
      <a href="/contact-us" class="navigation-link"><span class="navigation-button">CONTACT US</span></a>
    </nav>

    <!-- Auth buttons + theme -->
    <div id="user_buttons" class="flex items-center gap-2" style="flex-shrink: 0;">
      <!-- Calendar availability button — fixed width prevents layout shift -->
      <button
        id="preview"
        class="flex items-center justify-center gap-1.5 rounded-lg font-semibold transition-all duration-200"
        style="border: 2px solid #4a7c3f; color: #4a7c3f; font-size: 0.85rem; white-space: nowrap; background: transparent; cursor: pointer; width: 120px; height: 34px; flex-shrink: 0;"
      >
        <!-- Calendar icon (shown when closed) -->
        <svg id="previewIconCal" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <rect x="3" y="4" width="18" height="18" rx="2"/>
          <line x1="3" y1="10" x2="21" y2="10"/>
          <line x1="8" y1="2" x2="8" y2="6"/>
          <line x1="16" y1="2" x2="16" y2="6"/>
        </svg>
        <!-- X icon (shown when open) -->
        <svg id="previewIconX" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" width="13" height="13" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" style="display:none;">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
        <span id="previewText">Availability</span>
      </button>

      {!user && (
        <a href="/signin"
          class="flex items-center justify-center px-4 py-1.5 rounded-lg font-semibold transition-all duration-300"
          style="border: 2px solid #4a7c3f; color: #4a7c3f; font-size: 0.85rem; white-space: nowrap;">
          Log In
        </a>
      )}
      {!user && (
        <a href="/signup"
          class="flex items-center justify-center px-4 py-1.5 rounded-lg font-semibold transition-all duration-300 text-white"
          style="background-color: #1a1a1a; font-size: 0.85rem; white-space: nowrap;">
          Sign Up
        </a>
      )}
      {user && isAdmin && (
        <a href="/dashboard"
          class="flex items-center justify-center px-4 py-1.5 rounded-lg font-semibold transition-all duration-300 text-white"
          style="background-color: #4a7c3f; font-size: 0.85rem;">
          Dashboard
        </a>
      )}
      {user && isAdmin && (
        <a href="/admin"
          class="flex items-center justify-center px-4 py-1.5 rounded-lg font-semibold transition-all duration-300 text-white"
          style="background-color: #1a1a1a; font-size: 0.85rem;">
          Admin
        </a>
      )}
      {user && !isAdmin && (
        <a href="/dashboard"
          class="flex items-center justify-center px-4 py-1.5 rounded-lg font-semibold transition-all duration-300 text-white"
          style="background-color: #1a1a1a; font-size: 0.85rem;">
          My Dashboard
        </a>
      )}
      <span class="flex items-center">
        <Theme />
      </span>
    </div>
  </div>
</header>
<CalendarPreview />

<script>
  // Calendar open/close is handled by calendarPreview.astro
  // Keeping only smooth scroll for in-page anchor links
  function updatePreviewButton() {
    // noop — handled in calendarPreview
    if (false) {
    }
  }

  // Smooth scroll for in-page anchor links
  document.querySelectorAll('.scroll-link').forEach((link) => {
    link.addEventListener('click', (e) => {
      const href = (link as HTMLAnchorElement).getAttribute('href') || '';
      if (href.startsWith('/#') && window.location.pathname === '/') {
        e.preventDefault();
        const targetId = href.slice(2);
        const target = document.getElementById(targetId);
        if (target) {
          const navHeight = document.getElementById('navbar')?.offsetHeight || 52;
          const top = target.getBoundingClientRect().top + window.scrollY - navHeight;
          window.scrollTo({ top, behavior: 'smooth' });
        }
      }
    });
  });
</script>