---
const { venue, isLoggedIn = false } = Astro.props;
const bookingUrl = `/events_and_booking/events/${venue.id}`;
const venueName = venue.name || 'this venue';
---

<!-- Refactored to receive individual venue as prop and render single card -->
<div
  class="event-card wb-card wb-card--interactive overflow-hidden w-full h-full flex flex-col"
>
  {
    venue.image_url && (
      <img
        src={venue.image_url || '/placeholder.svg'}
        alt={venueName}
        class="event-card__image"
      />
    )
  }

  <div class="event-card__body">
    <h3 class="event-card__title">
      {venueName}
    </h3>

    {
      venue.description && (
        <p class="event-card__description">
          {venue.description.substring(0, 100)}...
        </p>
      )
    }

    {
      venue.price_per_night && (
        <div class="event-card__price">
          <p class="event-card__price-label">Starting from</p>
          <p class="event-card__price-value">
            ${venue.price_per_night}
            <span>/night</span>
          </p>
        </div>
      )
    }

    {
      isLoggedIn ? (
        <a
          href={bookingUrl}
          class="event-card__book-button"
        >
          Book Now
        </a>
      ) : (
        <>
          <button
            type="button"
            class="event-card__book-button"
            data-login-required-trigger={venue.id}
          >
            Book Now
          </button>

          <div
            class="login-required-modal hidden"
            data-login-required-modal={venue.id}
            role="presentation"
          >
            <div
              class="login-required-modal__card"
              role="dialog"
              aria-modal="true"
              aria-labelledby={`login-required-title-${venue.id}`}
            >
              <button
                type="button"
                class="login-required-modal__close"
                data-login-required-close
                aria-label="Close login prompt"
              >
                X
              </button>
              <p class="login-required-modal__eyebrow">Booking Access</p>
              <h3 id={`login-required-title-${venue.id}`}>
                Sign in to continue
              </h3>
              <p class="login-required-modal__message">
                You must be logged in to book <strong>{venueName}</strong>.
              </p>
              <div class="login-required-modal__actions">
                <a href="/signin" class="login-required-modal__button login-required-modal__button--primary">
                  Log In
                </a>
                <a href="/signup" class="login-required-modal__button login-required-modal__button--secondary">
                  Sign Up
                </a>
              </div>
            </div>
          </div>
        </>
      )
    }
  </div>
</div>

<script>
  if (!document.documentElement.dataset.loginRequiredModalBound) {
    document.documentElement.dataset.loginRequiredModalBound = 'true';

    const getModal = (venueId: string | null) => {
      if (!venueId) return undefined;

      return Array.from(
        document.querySelectorAll('[data-login-required-modal]')
      ).find(
        (modal) => modal.getAttribute('data-login-required-modal') === venueId
      );
    };

    const closeModals = () => {
      document
        .querySelectorAll('[data-login-required-modal]')
        .forEach((modal) => modal.classList.add('hidden'));
      document.body.style.overflow = '';
    };

    document.addEventListener('click', (event) => {
      const target = event.target;
      if (!(target instanceof Element)) return;

      const trigger = target.closest('[data-login-required-trigger]');
      if (trigger) {
        const modal = getModal(
          trigger.getAttribute('data-login-required-trigger')
        );
        if (modal) {
          modal.classList.remove('hidden');
          document.body.style.overflow = 'hidden';
        }
        return;
      }

      if (target.closest('[data-login-required-close]')) {
        closeModals();
        return;
      }

      const modal = target.closest('[data-login-required-modal]');
      if (modal && target === modal) closeModals();
    });

    document.addEventListener('keydown', (event) => {
      if (event.key === 'Escape') closeModals();
    });
  }
</script>

<style>
  .event-card {
    border-radius: var(--wb-radius-lg);
  }

  .event-card__image {
    width: 100%;
    height: 13rem;
    object-fit: cover;
  }

  .event-card__body {
    display: flex;
    flex: 1;
    flex-direction: column;
    padding: clamp(1.1rem, 3vw, 1.5rem);
  }

  .event-card__title {
    margin: 0;
    color: var(--wb-green-dark);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.25rem, 3vw, 1.55rem);
    letter-spacing: 0;
    line-height: 1.2;
  }

  .event-card__description {
    flex: 1;
    margin: 0.65rem 0 1.1rem;
    color: var(--wb-muted);
    font-size: 0.94rem;
    line-height: 1.6;
  }

  .event-card__price {
    margin-bottom: 1.1rem;
  }

  .event-card__price-label {
    margin: 0;
    color: var(--wb-muted);
    font-size: 0.78rem;
    font-weight: 800;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .event-card__price-value {
    margin: 0.15rem 0 0;
    color: var(--wb-warm);
    font-size: 1.7rem;
    font-weight: 900;
    line-height: 1.1;
  }

  .event-card__price-value span {
    color: var(--wb-muted);
    font-size: 0.9rem;
    font-weight: 700;
  }

  .event-card__book-button {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    justify-content: center;
    margin-top: auto;
    border: 0;
    border-radius: var(--wb-radius-sm);
    background: var(--wb-green);
    box-shadow: 0 12px 22px rgba(74, 124, 63, 0.16);
    color: #ffffff;
    cursor: pointer;
    font-size: 0.86rem;
    font-weight: 900;
    line-height: 1.25;
    padding: 0.75rem 1rem;
    text-align: center;
    text-decoration: none;
    transition:
      background-color 0.2s ease,
      box-shadow 0.2s ease,
      transform 0.2s ease;
  }

  .event-card__book-button:hover {
    background: var(--wb-green-mid);
    box-shadow: var(--wb-shadow-md);
    transform: translateY(-1px);
  }

  .login-required-modal {
    position: fixed;
    inset: 0;
    z-index: 70;
    display: grid;
    place-items: center;
    background: rgba(26, 46, 16, 0.56);
    padding: 1rem;
    backdrop-filter: blur(3px);
  }

  .login-required-modal.hidden {
    display: none;
  }

  .login-required-modal__card {
    position: relative;
    width: min(100%, 29rem);
    border: 1px solid rgba(221, 232, 212, 0.95);
    border-radius: var(--wb-radius-lg, 18px);
    background:
      radial-gradient(circle at top right, rgba(232, 242, 227, 0.98), transparent 12rem),
      var(--wb-surface-raised, #ffffff);
    box-shadow: var(--wb-shadow-lg, 0 18px 44px rgba(26, 46, 16, 0.16));
    color: var(--wb-text, #363537);
    padding: clamp(1.35rem, 4vw, 1.8rem);
  }

  .login-required-modal__close {
    position: absolute;
    top: 0.85rem;
    right: 0.85rem;
    display: grid;
    width: 2.1rem;
    height: 2.1rem;
    place-items: center;
    border: 1px solid var(--wb-border, #dde8d4);
    border-radius: 999px;
    background: var(--wb-surface-soft, #f7f9f4);
    color: var(--wb-green-mid, #2d5a27);
    cursor: pointer;
    font-size: 0.82rem;
    font-weight: 900;
    line-height: 1;
  }

  .login-required-modal__close:hover {
    background: var(--wb-green-soft, #e8f2e3);
    color: var(--wb-green-dark, #1a2e10);
  }

  .login-required-modal__eyebrow {
    margin: 0 2.5rem 0.35rem 0;
    color: var(--wb-green, #4a7c3f);
    font-size: 0.72rem;
    font-weight: 900;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  .login-required-modal h3 {
    margin: 0;
    color: var(--wb-green-dark, #1a2e10);
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(1.6rem, 6vw, 2.15rem);
    letter-spacing: 0;
    line-height: 1.1;
  }

  .login-required-modal__message {
    margin: 0.85rem 0 0;
    color: var(--wb-muted, #5a6b52);
    font-size: 0.98rem;
    line-height: 1.55;
  }

  .login-required-modal__message strong {
    color: var(--wb-green-dark, #1a2e10);
  }

  .login-required-modal__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
    margin-top: 1.35rem;
  }

  .login-required-modal__button {
    display: inline-flex;
    min-height: 2.75rem;
    flex: 1 1 10rem;
    align-items: center;
    justify-content: center;
    border: 1px solid transparent;
    border-radius: var(--wb-radius-md, 12px);
    font-size: 0.84rem;
    font-weight: 900;
    padding: 0.8rem 1rem;
    text-align: center;
    text-decoration: none;
    text-transform: uppercase;
  }

  .login-required-modal__button--primary {
    background: var(--wb-green, #4a7c3f);
    box-shadow: 0 12px 22px rgba(74, 124, 63, 0.18);
    color: #ffffff;
  }

  .login-required-modal__button--primary:hover {
    background: var(--wb-green-mid, #2d5a27);
  }

  .login-required-modal__button--secondary {
    border-color: var(--wb-border, #dde8d4);
    background: var(--wb-surface-soft, #f7f9f4);
    color: var(--wb-green-mid, #2d5a27);
  }

  .login-required-modal__button--secondary:hover {
    background: var(--wb-green-soft, #e8f2e3);
    color: var(--wb-green-dark, #1a2e10);
  }

  :global(html.dark) .login-required-modal__card,
  :global(html.dark) .login-required-modal__close,
  :global(html.dark) .login-required-modal__button--secondary {
    background: var(--wb-surface-raised);
    border-color: var(--wb-border);
  }

  :global(html.dark) .login-required-modal__button--secondary:hover,
  :global(html.dark) .login-required-modal__close:hover {
    background: var(--wb-green-soft);
  }

  :global(html.dark) .event-card__book-button {
    background: var(--wb-green-mid);
    color: #10170e;
  }

  :global(html.dark) .event-card__book-button:hover {
    background: #d5efc9;
  }
</style>
