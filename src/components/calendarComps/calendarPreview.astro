---
/**
 * Woodberry Availability Calendar — real data from Supabase
 * Drops down below navbar. No layout shift.
 */
---

<div
  id="availabilityPanel"
  class="fixed left-0 right-0 z-50 opacity-0 pointer-events-none transition-all duration-300 -translate-y-2"
  style="top: 70px;"
>
  <div style="max-width: 480px; margin-left: auto; margin-right: 1.5rem;">
    <div
      class="rounded-2xl shadow-2xl overflow-hidden"
      style="background:#fff; border:1px solid rgba(74,124,63,0.15); box-shadow:0 20px 60px rgba(0,0,0,0.15),0 4px 16px rgba(74,124,63,0.1);"
    >
      <!-- Header with month nav -->
      <div
        class="flex items-center justify-between px-5 py-4"
        style="background:linear-gradient(135deg,#2d5a27 0%,#4a7c3f 60%,#5a9e50 100%);"
      >
        <button id="prevMonth" style="background:rgba(255,255,255,0.15);color:#fff;border:none;cursor:pointer;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;" aria-label="Previous month">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="15 18 9 12 15 6"/></svg>
        </button>
        <div class="text-center">
          <div id="calMonthYear" style="color:#fff;font-weight:700;font-size:1.1rem;font-family:Georgia,serif;letter-spacing:0.04em;"></div>
          <div style="color:rgba(255,255,255,0.7);font-size:0.72rem;margin-top:2px;">Availability Overview</div>
        </div>
        <button id="nextMonth" style="background:rgba(255,255,255,0.15);color:#fff;border:none;cursor:pointer;width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;" aria-label="Next month">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="9 18 15 12 9 6"/></svg>
        </button>
      </div>

      <!-- Day headers -->
      <div style="display:grid;grid-template-columns:repeat(7,1fr);padding:12px 16px 4px;">
        {['Mon','Tue','Wed','Thu','Fri','Sat','Sun'].map(d => (
          <div style="text-align:center;font-size:0.72rem;font-weight:600;color:#999;letter-spacing:0.05em;">{d}</div>
        ))}
      </div>

      <!-- Calendar grid -->
      <div id="calGrid" style="display:grid;grid-template-columns:repeat(7,1fr);gap:4px;padding:4px 16px 12px;"></div>

      <!-- Loading indicator -->
      <div id="calLoading" style="display:none;text-align:center;padding:8px;font-size:0.75rem;color:#888;">Loading…</div>

      <div style="height:1px;background:rgba(74,124,63,0.1);margin:0 1rem;"></div>

      <!-- Legend -->
      <div style="padding:10px 20px;display:flex;align-items:center;justify-content:center;gap:16px;flex-wrap:wrap;">
        <span style="font-size:0.7rem;font-weight:700;color:#aaa;letter-spacing:0.05em;">LEGEND</span>
        {[
          { color:'#22c55e', label:'Available' },
          { color:'#ef4444', label:'Booked' },
          { color:'#3b82f6', label:'Contract Signing' },
          { color:'#e5e7eb', label:'Unavailable' },
        ].map(item => (
          <div style="display:flex;align-items:center;gap:6px;">
            <div style={`width:10px;height:10px;border-radius:50%;background:${item.color};flex-shrink:0;`}></div>
            <span style="font-size:0.75rem;color:#555;">{item.label}</span>
          </div>
        ))}
      </div>

      <!-- CTA -->
      <div style="padding:4px 20px 16px;">
        <a href="/events_and_booking/events" style="display:flex;align-items:center;justify-content:center;gap:8px;width:100%;padding:10px;border-radius:12px;background:linear-gradient(135deg,#2d5a27,#4a7c3f);color:#fff;text-decoration:none;font-weight:600;font-size:0.875rem;">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="3" y1="10" x2="21" y2="10"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="16" y1="2" x2="16" y2="6"/></svg>
          Book a Date
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  const today     = new Date();
  let viewYear    = today.getFullYear();
  let viewMonth   = today.getMonth(); // 0-indexed

  const panel      = document.getElementById('availabilityPanel')!;
  const grid       = document.getElementById('calGrid')!;
  const loading    = document.getElementById('calLoading')!;
  const monthLabel = document.getElementById('calMonthYear')!;
  const prevBtn    = document.getElementById('prevMonth')!;
  const nextBtn    = document.getElementById('nextMonth')!;

  const MONTHS = ['January','February','March','April','May','June',
                  'July','August','September','October','November','December'];

  function formatDateOnly(date: Date) {
    return `${date.getFullYear()}-${String(date.getMonth() + 1).padStart(2,'0')}-${String(date.getDate()).padStart(2,'0')}`;
  }

  function addOneCalendarMonth(date: Date) {
    const oneMonthLater = new Date(date.getFullYear(), date.getMonth() + 1, date.getDate());
    if (oneMonthLater.getDate() !== date.getDate()) {
      oneMonthLater.setDate(0);
    }
    return oneMonthLater;
  }

  const todayDateOnly = new Date(today.getFullYear(), today.getMonth(), today.getDate());
  const minimumBookingDateISO = formatDateOnly(addOneCalendarMonth(todayDateOnly));

  // Cache fetched data per "YYYY-MM" key
  const cache: Record<string, Set<string>> = {};

  async function fetchBookedDates(year: number, month: number): Promise<Set<string>> {
    const key = `${year}-${month}`;
    if (cache[key]) return cache[key];

    loading.style.display = 'block';
    try {
      const res  = await fetch(`/api/bookings/availability?year=${year}&month=${month + 1}`);
      const json = await res.json();
      const booked = new Set<string>();
      const contractSigning = new Set<string>();

      for (const b of (json.bookings ?? [])) {
        // Mark every day in start_date..end_date range
        const start = new Date(b.start_date + 'T00:00:00');
        const end   = new Date(b.end_date   + 'T00:00:00');
        for (let d = new Date(start); d <= end; d.setDate(d.getDate() + 1)) {
          const iso = d.toISOString().split('T')[0];
          if (b.status === 'contract_signing') contractSigning.add(iso);
          else booked.add(iso);
        }
        // Also mark event_date if set
        if (b.event_date) {
          if (b.status === 'contract_signing') contractSigning.add(b.event_date.split('T')[0]);
          else booked.add(b.event_date.split('T')[0]);
        }
      }

      // Store combined: booked/rescheduled/completed overrides contract signing
      const combined = new Set<string>();
      contractSigning.forEach(d => combined.add('c:' + d));   // prefix c = contract signing
      booked.forEach(d  => combined.add('b:' + d));   // prefix b = booked/rescheduled

      cache[key] = combined;
      return combined;
    } catch {
      return new Set();
    } finally {
      loading.style.display = 'none';
    }
  }

  async function renderCalendar() {
    monthLabel.textContent = `${MONTHS[viewMonth]} ${viewYear}`;
    grid.innerHTML = '';

    const bookedSet = await fetchBookedDates(viewYear, viewMonth);

    const firstDow  = new Date(viewYear, viewMonth, 1).getDay();
    const offset    = (firstDow + 6) % 7; // Mon-start
    const daysInMo  = new Date(viewYear, viewMonth + 1, 0).getDate();
    const total     = Math.ceil((offset + daysInMo) / 7) * 7;
    const todayISO  = formatDateOnly(todayDateOnly);

    for (let i = 0; i < total; i++) {
      const dayNum = i - offset + 1;
      const cell   = document.createElement('div');
      cell.style.cssText = 'aspect-ratio:1;display:flex;align-items:center;justify-content:center;border-radius:8px;font-size:0.78rem;font-weight:600;position:relative;transition:transform 0.12s,box-shadow 0.12s;';

      if (dayNum < 1 || dayNum > daysInMo) {
        cell.style.background = 'transparent';
      } else {
        const dateISO = `${viewYear}-${String(viewMonth + 1).padStart(2,'0')}-${String(dayNum).padStart(2,'0')}`;
        const isToday = dateISO === todayISO;
        const isPast  = dateISO < todayISO;
        const isTooSoon = dateISO < minimumBookingDateISO;
        const isBooked   = bookedSet.has('b:' + dateISO);
        const isContractSigning  = !isBooked && bookedSet.has('c:' + dateISO);

        let bg = '#f0fdf4', textColor = '#166534', ring = '#22c55e'; // available
        if (isPast || isTooSoon) {
          bg = '#f9fafb'; textColor = '#d1d5db'; ring = '#e5e7eb';
        } else if (isBooked) {
          bg = '#fef2f2'; textColor = '#991b1b'; ring = '#ef4444';
        } else if (isContractSigning) {
          bg = '#eff6ff'; textColor = '#1d4ed8'; ring = '#3b82f6';
        }

        cell.style.background = bg;
        cell.style.color = textColor;
        cell.style.outline = isToday ? `2.5px solid #2d5a27` : `1.5px solid ${ring}`;
        if (isToday) cell.style.boxShadow = '0 0 0 3px rgba(45,90,39,0.18)';
        cell.textContent = String(dayNum);

        if (!isPast && !isTooSoon) {
          cell.style.cursor = 'pointer';
          cell.addEventListener('mouseenter', () => {
            cell.style.transform = 'scale(1.12)';
            cell.style.boxShadow = `0 4px 12px rgba(0,0,0,0.12)`;
            cell.style.zIndex = '10';
          });
          cell.addEventListener('mouseleave', () => {
            cell.style.transform = '';
            cell.style.boxShadow = isToday ? '0 0 0 3px rgba(45,90,39,0.18)' : '';
            cell.style.zIndex = '';
          });
        }
      }
      grid.appendChild(cell);
    }
  }

  // ── Button state ──────────────────────────────────────────────────────────
  function setButtonOpen(open: boolean) {
    const txt     = document.getElementById('previewText');
    const iconCal = document.getElementById('previewIconCal') as HTMLElement | null;
    const iconX   = document.getElementById('previewIconX')   as HTMLElement | null;
    if (txt)     txt.textContent       = open ? 'Close'  : 'Availability';
    if (iconCal) iconCal.style.display = open ? 'none'   : 'block';
    if (iconX)   iconX.style.display   = open ? 'block'  : 'none';
  }

  function openPanel() {
    panel.classList.remove('opacity-0','pointer-events-none','-translate-y-2');
    panel.classList.add('opacity-100','pointer-events-auto','translate-y-0');
    setButtonOpen(true);
  }
  function closePanel() {
    panel.classList.add('opacity-0','pointer-events-none','-translate-y-2');
    panel.classList.remove('opacity-100','pointer-events-auto','translate-y-0');
    setButtonOpen(false);
  }

  prevBtn.addEventListener('click', () => {
    if (viewMonth === 0) { viewMonth = 11; viewYear--; } else { viewMonth--; }
    renderCalendar();
  });
  nextBtn.addEventListener('click', () => {
    if (viewMonth === 11) { viewMonth = 0; viewYear++; } else { viewMonth++; }
    renderCalendar();
  });

  document.addEventListener('click', (e) => {
    if (!(e.target instanceof Element)) return;
    const clickedToggle  = e.target.closest('#preview');
    const clickedInPanel = panel.contains(e.target);
    const isOpen = panel.classList.contains('opacity-100');
    if (clickedToggle) { isOpen ? closePanel() : openPanel(); return; }
    if (!clickedInPanel && isOpen) closePanel();
  });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closePanel(); });

  renderCalendar();
</script>
